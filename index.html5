<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>足場プランナー</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@400;500;700&display=swap');
  :root {
    --bg:#1a1e2a;--surface:#222736;--surface2:#2a3045;
    --accent:#00d4ff;--accent2:#f4a100;
    --sep:#2a3555;--text:#c8d0e0;--text-dim:#5a6480;
    --radius:10px;--danger:#e03e3e;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  body{font-family:'Noto Sans JP',sans-serif;background:var(--bg);color:var(--text);height:100dvh;display:flex;flex-direction:column;overflow:hidden;}

  header{padding:8px 14px 6px;background:var(--surface);border-bottom:1px solid var(--sep);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
  header h1{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;color:var(--accent);line-height:1;}
  header .sub{font-size:9px;color:var(--text-dim);margin-top:1px;}

  .toolbar{display:flex;align-items:center;gap:5px;padding:6px 10px;background:var(--surface);border-bottom:1px solid var(--sep);flex-shrink:0;overflow-x:auto;scrollbar-width:none;}
  .toolbar::-webkit-scrollbar{display:none;}
  .tsep{width:1px;height:18px;background:var(--sep);flex-shrink:0;margin:0 2px;}
  .tlabel{font-size:10px;color:var(--text-dim);flex-shrink:0;white-space:nowrap;}
  .tbtn{flex-shrink:0;padding:5px 11px;border-radius:14px;border:1px solid var(--sep);background:transparent;color:var(--text-dim);font-size:11px;font-family:'Noto Sans JP',sans-serif;font-weight:500;cursor:pointer;transition:all 0.15s;white-space:nowrap;}
  .tbtn.at{background:var(--accent);border-color:var(--accent);color:#000;font-weight:700;}
  .tbtn.et{background:var(--danger);border-color:var(--danger);color:#fff;font-weight:700;}
  .tbtn.mt{background:#22cc88;border-color:#22cc88;color:#000;font-weight:700;}
  .tbtn.disabled{opacity:0.3;pointer-events:none;}
  .tbtn.aw{background:#a259ff;border-color:#a259ff;color:#fff;font-weight:700;}
  .tbtn.as{background:var(--accent2);border-color:var(--accent2);color:#000;font-weight:700;}

  .canvas-wrap{flex:1;overflow:auto;background:#0a0c12;padding:6px;}
  canvas{display:block;touch-action:none;cursor:crosshair;}

  .stat-bar{display:flex;gap:10px;padding:5px 12px;background:var(--surface2);border-top:1px solid var(--sep);font-size:11px;color:var(--text-dim);flex-shrink:0;}
  .stat-item span{color:var(--accent);font-weight:700;}

  .controls{background:var(--surface);border-top:1px solid var(--sep);flex-shrink:0;}
  .ctrl-row{display:flex;align-items:center;gap:8px;padding:6px 12px;border-bottom:1px solid var(--sep);}
  .ctrl-lbl{font-size:11px;color:var(--text-dim);white-space:nowrap;min-width:32px;}
  .seg-btn{padding:4px 10px;border-radius:12px;border:1px solid var(--sep);background:transparent;color:var(--text-dim);font-size:11px;font-family:'Noto Sans JP',sans-serif;font-weight:500;cursor:pointer;transition:all 0.15s;}
  .seg-btn.active{border-color:var(--accent2);color:var(--accent2);font-weight:700;background:#f4a10015;}
  .dan-counter{display:flex;align-items:center;gap:6px;}
  .dan-btn{width:26px;height:26px;border-radius:50%;border:none;font-size:16px;font-weight:bold;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .dan-btn.minus{background:var(--surface2);color:var(--text);}
  .dan-btn.plus{background:var(--accent2);color:#000;}
  .dan-val{font-size:18px;font-weight:700;color:var(--accent2);min-width:22px;text-align:center;}
  .btn-row{display:flex;gap:8px;padding:7px 12px;}
  .calc-btn{flex:1;padding:11px;background:var(--accent2);color:#000;border:none;border-radius:var(--radius);font-size:13px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .calc-btn:active{background:#d98e00;}
  .clear-btn{padding:11px 14px;background:transparent;color:var(--danger);border:1px solid var(--danger);border-radius:var(--radius);font-size:12px;font-weight:600;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}

  .toolbar2{border-top:none;}
  .legend-inline{display:flex;gap:8px;align-items:center;flex-shrink:0;}
  .legend-item{display:flex;align-items:center;gap:3px;font-size:10px;color:var(--text-dim);}
  .ldot{width:9px;height:9px;border-radius:2px;border:1.5px solid;flex-shrink:0;}

  /* メニューボタン */
  .menu-btn{background:transparent;border:1px solid var(--sep);color:var(--text);font-size:18px;width:36px;height:36px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .menu-btn:active{background:var(--surface2);}

  /* メニューパネル */
  .menu-overlay{display:none;position:fixed;inset:0;background:#00000077;z-index:300;}
  .menu-overlay.visible{display:block;}
  .menu-panel{position:absolute;top:0;right:0;width:min(320px,90vw);height:100%;background:var(--surface);display:flex;flex-direction:column;box-shadow:-4px 0 20px #0008;}
  .menu-header{display:flex;justify-content:space-between;align-items:center;padding:16px;border-bottom:1px solid var(--sep);flex-shrink:0;}
  .menu-title{font-size:16px;font-weight:700;color:var(--text);}
  .menu-close{background:transparent;border:1px solid var(--sep);color:var(--text);font-size:18px;width:32px;height:32px;border-radius:50%;cursor:pointer;}
  .menu-tabs{display:flex;border-bottom:1px solid var(--sep);flex-shrink:0;overflow-x:auto;scrollbar-width:none;}
  .menu-tabs::-webkit-scrollbar{display:none;}
  .menu-tab{flex-shrink:0;padding:10px 10px;background:transparent;border:none;border-bottom:2px solid transparent;color:var(--text-dim);font-size:12px;font-family:'Noto Sans JP',sans-serif;font-weight:500;cursor:pointer;transition:all 0.15s;white-space:nowrap;}
  .menu-tab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:700;}

  /* バージョン */
  .version-badge{display:inline-block;background:var(--accent);color:#000;font-size:13px;font-weight:700;padding:6px 14px;border-radius:20px;margin-bottom:4px;}
  .update-list{display:flex;flex-direction:column;gap:16px;}
  .update-item{background:var(--surface2);border-radius:10px;padding:14px;}
  .update-ver{font-size:13px;font-weight:700;color:var(--accent);margin-bottom:2px;}
  .update-date{font-size:11px;color:var(--text-dim);margin-bottom:8px;}
  .update-notes{display:flex;flex-direction:column;gap:4px;}
  .update-note{font-size:13px;color:var(--text);}

  /* プライバシー */
  .privacy-text{display:flex;flex-direction:column;gap:16px;}
  .privacy-section{background:var(--surface2);border-radius:10px;padding:14px;}
  .privacy-heading{font-size:13px;font-weight:700;color:var(--accent2);margin-bottom:6px;}
  .privacy-body{font-size:12px;color:var(--text);line-height:1.7;}

  /* お問い合わせ */
  .contact-body{display:flex;flex-direction:column;gap:14px;}
  .contact-desc{font-size:13px;color:var(--text);line-height:1.7;}
  .contact-item{background:var(--surface2);border-radius:10px;padding:14px;}
  .contact-label{font-size:11px;color:var(--text-dim);margin-bottom:4px;}
  .contact-value{font-size:14px;color:var(--accent);font-weight:600;}
  .contact-note{font-size:11px;color:var(--text-dim);}
  .feedback-list{display:flex;flex-direction:column;gap:8px;}
  .feedback-item{background:var(--surface2);border-radius:8px;padding:12px;font-size:13px;color:var(--text);}
  .menu-content{flex:1;overflow-y:auto;padding:16px;}
  .menu-sec-title{font-size:11px;color:var(--text-dim);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;}

  /* 色設定 */
  .color-row-wrap{border-bottom:1px solid var(--sep);padding:12px 0;}
  .color-row-wrap:last-child{border-bottom:none;}
  .color-row-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
  .color-row-label{font-size:14px;color:var(--text);font-weight:600;}
  .color-cur-dot{font-size:11px;padding:3px 10px;border-radius:12px;border:2px solid;color:#000;font-weight:700;}
  .cgroups{display:flex;flex-direction:column;gap:6px;}
  .cgroup{display:flex;align-items:center;gap:6px;}
  .cgroup-label{font-size:10px;color:var(--text-dim);min-width:52px;flex-shrink:0;}
  .cgroup-swatches{display:flex;gap:6px;}
  .cswatch{width:30px;height:30px;border-radius:8px;border:2px solid transparent;cursor:pointer;transition:transform 0.1s;flex-shrink:0;}
  .cswatch:active{transform:scale(0.85);}
  .cswatch.sel{border-color:#fff;transform:scale(1.15);}

  /* 使い方 */
  .info-list{display:flex;flex-direction:column;gap:8px;}
  .info-row{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text);}
  .info-row span{color:var(--accent);font-weight:700;min-width:52px;flex-shrink:0;}

  /* 凡例info */
  .legend-info-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--sep);font-size:13px;color:var(--text);}
  .legend-info-row:last-child{border-bottom:none;}
  .legend-info-dot{width:20px;height:20px;border-radius:4px;border:2px solid;flex-shrink:0;}

  .modal-overlay{display:none;position:fixed;inset:0;background:#00000099;z-index:100;align-items:flex-end;}
  .modal-overlay.visible{display:flex;}
  .modal{width:100%;max-height:80dvh;background:var(--surface);border-radius:16px 16px 0 0;overflow-y:auto;border-top:2px solid var(--accent);}
  .modal-header{position:sticky;top:0;background:var(--surface);padding:12px 16px 8px;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid var(--sep);}
  .modal-title{font-size:13px;color:var(--accent);font-weight:700;letter-spacing:1px;}
  .modal-sub{font-size:11px;color:var(--text-dim);margin-top:2px;}
  .modal-close{width:30px;height:30px;border-radius:50%;border:1px solid var(--sep);background:var(--surface2);color:var(--text);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .result-sec{padding:8px 16px 2px;font-size:10px;color:var(--text-dim);font-weight:700;letter-spacing:1px;text-transform:uppercase;border-top:1px solid var(--sep);}
  .result-row{display:flex;justify-content:space-between;align-items:center;padding:9px 16px;border-bottom:1px solid #ffffff08;}
  .result-row:last-child{border-bottom:none;}
  .rname{font-size:14px;color:var(--text);}
  .rqty{font-size:20px;font-weight:700;color:var(--accent2);}
  .runit{font-size:11px;color:var(--text-dim);margin-left:2px;}
  /* 保存・読み込み */
  .save-input-row{display:flex;gap:8px;margin-bottom:4px;}
  .save-input{flex:1;background:var(--surface2);border:1px solid var(--sep);border-radius:8px;padding:10px 12px;color:var(--text);font-size:14px;font-family:'Noto Sans JP',sans-serif;outline:none;}
  .save-input:focus{border-color:var(--accent);}
  .save-btn{padding:10px 16px;background:var(--accent);color:#000;border:none;border-radius:8px;font-size:13px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;white-space:nowrap;}
  .save-btn:active{background:#00aad4;}
  .saved-item{background:var(--surface2);border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
  .saved-item-info{flex:1;min-width:0;}
  .saved-item-title{font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .saved-item-date{font-size:11px;color:var(--text-dim);margin-top:2px;}
  .saved-item-blocks{font-size:11px;color:var(--accent);margin-top:1px;}
  .saved-item-btns{display:flex;gap:6px;flex-shrink:0;}
  .load-btn{padding:6px 12px;background:var(--accent2);color:#000;border:none;border-radius:6px;font-size:12px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .del-btn{padding:6px 10px;background:transparent;color:var(--danger);border:1px solid var(--danger);border-radius:6px;font-size:12px;cursor:pointer;}

</style>
</head>
<body>

<header>
  <div>
    <h1>足場プランナー</h1>
    <div class="sub" id="header-sub">幅: 610mm / スパン: 1829mm / 縦置き</div>
  </div>
  <button class="menu-btn" onclick="openMenu()">☰</button>
</header>

<!-- メニューパネル（右からスライド） -->
<div class="menu-overlay" id="menu-overlay" onclick="closeMenuOverlay(event)">
  <div class="menu-panel" onclick="event.stopPropagation()">
    <div class="menu-header">
      <div class="menu-title">メニュー</div>
      <button class="menu-close" onclick="closeMenu()">×</button>
    </div>
    <div class="menu-tabs">
      <button class="menu-tab active" id="tab-color"   onclick="switchTab('color')">🎨 色</button>
      <button class="menu-tab"        id="tab-save"    onclick="switchTab('save')">💾 保存</button>
      <button class="menu-tab"        id="tab-info"    onclick="switchTab('info')">📖 使い方</button>
      <button class="menu-tab"        id="tab-updates" onclick="switchTab('updates')">🆕 更新</button>
      <button class="menu-tab"        id="tab-privacy" onclick="switchTab('privacy')">🔒 規約</button>
      <button class="menu-tab"        id="tab-contact" onclick="switchTab('contact')">✉️ お問合せ</button>
    </div>

    <!-- 色設定 -->
    <div class="menu-content" id="content-color">
      <div class="menu-sec-title">スパン別の色</div>
      <div id="color-settings"></div>
    </div>

    <!-- 保存・読み込み -->
    <div class="menu-content" id="content-save" style="display:none;">
      <div class="menu-sec-title">現在の図面を保存</div>
      <div class="save-input-row">
        <input class="save-input" id="save-title" type="text" placeholder="現場名・タイトルを入力" maxlength="30">
        <button class="save-btn" onclick="saveDrawing()">保存</button>
      </div>
      <div class="menu-sec-title" style="margin-top:20px;">保存済みの図面</div>
      <div id="saved-list"></div>
    </div>

    <!-- 使い方 -->
    <div class="menu-content" id="content-info" style="display:none;">
      <div class="menu-sec-title">凡例</div>
      <div id="legend-info"></div>

      <div class="menu-sec-title" style="margin-top:20px;">基本操作</div>
      <div class="info-list">
        <div class="info-row"><span>✏️ 配置</span>タップして指を離すと足場を置く</div>
        <div class="info-row"><span>🗑️ 消去</span>タップで足場を削除</div>
        <div class="info-row"><span>↩ / ↪</span>操作を1つ戻す・やり直す</div>
      </div>

      <div class="menu-sec-title" style="margin-top:20px;">画面操作</div>
      <div class="info-list">
        <div class="info-row"><span>2本指ドラッグ</span>画面を移動</div>
        <div class="info-row"><span>2本指ピンチ</span>拡大・縮小</div>
        <div class="info-row"><span>＋ / －</span>ボタンで拡大・縮小</div>
        <div class="info-row"><span>全体</span>元の倍率に戻す</div>
      </div>

      <div class="menu-sec-title" style="margin-top:20px;">足場の設定</div>
      <div class="info-list">
        <div class="info-row"><span>幅</span>610 / 914 / 1219mm から選択</div>
        <div class="info-row"><span>スパン</span>610〜1829mm から選択</div>
        <div class="info-row"><span>縦 / 横</span>スパンの向きを切替</div>
      </div>

      <div class="menu-sec-title" style="margin-top:20px;">保存・読み込み</div>
      <div class="info-list">
        <div class="info-row"><span>💾 保存</span>タイトルを入力して図面を保存</div>
        <div class="info-row"><span>読込</span>保存した図面を呼び出す</div>
        <div class="info-row"><span>削除</span>保存した図面を削除</div>
        <div class="info-row"><span>保存場所</span>端末内に保存（ネット不要）</div>
      </div>

      <div class="menu-sec-title" style="margin-top:20px;">色設定</div>
      <div class="info-list">
        <div class="info-row"><span>🎨 色タブ</span>スパンごとに18色から変更可能</div>
      </div>
    </div>

    <!-- 更新履歴 -->
    <div class="menu-content" id="content-updates" style="display:none;">
      <div class="menu-sec-title">バージョン情報</div>
      <div class="version-badge">ver 0.1.0 β</div>
      <div class="menu-sec-title" style="margin-top:20px;">更新履歴</div>
      <div class="update-list">
        <div class="update-item">
          <div class="update-ver">ver 0.1.0 β</div>
          <div class="update-date">2025年 β版リリース</div>
          <div class="update-notes">
            <div class="update-note">・足場図面の配置機能</div>
            <div class="update-note">・幅・スパン別の実寸比率表示</div>
            <div class="update-note">・縦置き・横置きの切替</div>
            <div class="update-note">・拡大縮小・移動機能</div>
            <div class="update-note">・スパン別カラー設定</div>
            <div class="update-note">・アンドゥ・リドゥ機能</div>
          </div>
        </div>
      </div>
    </div>

    <!-- プライバシーポリシー -->
    <div class="menu-content" id="content-privacy" style="display:none;">
      <div class="menu-sec-title">プライバシーポリシー</div>
      <div class="privacy-text">
        <div class="privacy-section">
          <div class="privacy-heading">個人情報の取り扱いについて</div>
          <div class="privacy-body">本アプリは、利用者の個人情報を一切収集・保存・送信しません。入力された図面データはお使いの端末内のみで処理されます。</div>
        </div>
        <div class="privacy-section">
          <div class="privacy-heading">広告について</div>
          <div class="privacy-body">本アプリは広告を表示する場合があります。広告配信のため、第三者の広告サービスが利用者の行動情報を収集することがあります。詳細は各広告サービスのプライバシーポリシーをご確認ください。</div>
        </div>
        <div class="privacy-section">
          <div class="privacy-heading">免責事項</div>
          <div class="privacy-body">本アプリの利用により生じた損害について、開発者は一切の責任を負いません。算出された数量はあくまで目安であり、実際の施工においては必ず現場確認を行ってください。</div>
        </div>
        <div class="privacy-section">
          <div class="privacy-heading">ポリシーの変更</div>
          <div class="privacy-body">本ポリシーは予告なく変更される場合があります。変更後も本アプリを継続してご利用された場合、変更に同意したものとみなします。</div>
        </div>
      </div>
    </div>

    <!-- お問い合わせ -->
    <div class="menu-content" id="content-contact" style="display:none;">
      <div class="menu-sec-title">お問い合わせ</div>
      <div class="contact-body">
        <div class="contact-desc">ご意見・ご要望・不具合の報告など、お気軽にご連絡ください。いただいたフィードバックは今後の改善に活かします。</div>
        <div class="contact-item">
          <div class="contact-label">✉️ メール</div>
          <div class="contact-value" id="contact-email">準備中</div>
        </div>
        <div class="contact-note">※ メールアドレスは近日公開予定です</div>
        <div class="menu-sec-title" style="margin-top:24px;">フィードバック募集中</div>
        <div class="feedback-list">
          <div class="feedback-item">🔧 こんな機能が欲しい</div>
          <div class="feedback-item">🐛 使いにくい・バグがある</div>
          <div class="feedback-item">💡 改善のアイデア</div>
          <div class="feedback-item">👍 良かった点</div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- 1段目：操作ツール・向き・ズーム -->
<div class="toolbar">
  <button class="tbtn at" id="btn-draw"   onclick="setTool('draw')">✏️ 配置</button>
  <button class="tbtn"    id="btn-erase"  onclick="setTool('erase')">🗑️ 消去</button>
  <div class="tsep"></div>
  <button class="tbtn" id="btn-undo" onclick="undo()">↩</button>
  <button class="tbtn" id="btn-redo" onclick="redo()">↪</button>
  <div class="tsep"></div>
  <div class="tlabel">向き:</div>
  <button class="tbtn mt" id="rot-tate" onclick="setRotate(false)">縦</button>
  <button class="tbtn"    id="rot-yoko" onclick="setRotate(true)">横</button>
  <div class="tsep"></div>
  <button class="tbtn" onclick="openSaveTab()">💾 保存</button>
  <div class="tsep"></div>
  <button class="tbtn" onclick="applyZoom(1.25)">＋</button>
  <span id="zoom-label" style="font-size:11px;color:var(--text-dim);min-width:32px;text-align:center;">100%</span>
  <button class="tbtn" onclick="applyZoom(1/1.25)">－</button>
  <button class="tbtn" onclick="resetZoom()" style="font-size:10px;">全体</button>
</div>

<!-- 2段目：幅・スパン・凡例 -->
<div class="toolbar toolbar2">
  <div class="tlabel">幅:</div>
  <button class="tbtn aw" id="w-610"  onclick="setWidth(610)">610</button>
  <button class="tbtn"    id="w-914"  onclick="setWidth(914)">914</button>
  <button class="tbtn"    id="w-1219" onclick="setWidth(1219)">1219</button>
  <div class="tsep"></div>
  <div class="tlabel">スパン:</div>
  <button class="tbtn"    id="s-610"  onclick="setSpan(610)">610</button>
  <button class="tbtn"    id="s-914"  onclick="setSpan(914)">914</button>
  <button class="tbtn"    id="s-1219" onclick="setSpan(1219)">1219</button>
  <button class="tbtn"    id="s-1524" onclick="setSpan(1524)">1524</button>
  <button class="tbtn as" id="s-1829" onclick="setSpan(1829)">1829</button>
  <div class="tsep"></div>
  <div class="legend-inline">
    <div class="legend-item"><div class="ldot" id="legend-dot-610"  style="background:#ff9ee033;border-color:#ff9ee0;"></div>610</div>
    <div class="legend-item"><div class="ldot" id="legend-dot-914"  style="background:#ffd93d33;border-color:#ffd93d;"></div>914</div>
    <div class="legend-item"><div class="ldot" id="legend-dot-1219" style="background:#6bcb7733;border-color:#6bcb77;"></div>1219</div>
    <div class="legend-item"><div class="ldot" id="legend-dot-1524" style="background:#ff6b6b33;border-color:#ff6b6b;"></div>1524</div>
    <div class="legend-item"><div class="ldot" id="legend-dot-1829" style="background:#00d4ff33;border-color:#00d4ff;"></div>1829</div>
  </div>
</div>

<div class="canvas-wrap" id="canvas-wrap">
  <canvas id="gc"></canvas>
</div>

<div class="stat-bar">
  <div class="stat-item">スパン数: <span id="stat-spans">0</span></div>
  <div class="stat-item">実長: <span id="stat-len">0</span>mm</div>
  <div class="stat-item">ブロック: <span id="stat-cells">0</span></div>
</div>

<div class="controls">
  <div class="btn-row">
    <button class="clear-btn" onclick="clearAll()">全消去</button>
  </div>
</div>

<script>
// ===== 定数 =====
const BASE_MM   = 305;  // グリッド最小単位 305mm（610の半分）
const GRID_COLS = 300;  // 300×305mm = 91,500mm（約91m）
const GRID_ROWS = 200;  // 200×305mm = 61,000mm（約61m）
const WIDTH_OPTIONS = [610,914,1219];
const SPAN_OPTIONS  = [610,914,1219,1524,1829];
const SPAN_COLORS  = {
  610:  {line:'#ff9ee0',fill:'#ff9ee010'},
  914:  {line:'#ffd93d',fill:'#ffd93d10'},
  1219: {line:'#6bcb77',fill:'#6bcb7710'},
  1524: {line:'#ff6b6b',fill:'#ff6b6b10'},
  1829: {line:'#00d4ff',fill:'#00d4ff10'},
};

// ===== 状態 =====
let blocks       = [];
let undoStack    = []; // 操作履歴
let redoStack    = []; // やり直し履歴
let tool         = 'draw';
let currentWidth = 610;
let currentSpan  = 1829;
let isRotated    = false;

// ポインタ状態
let isDown    = false;
let lastUpPos = null;
let previewPos = null;
let panStart  = null;
let dragStartPos = null; // ドラッグ開始位置（誤操作防止用）
const DRAG_THRESHOLD = 40; // この距離(px)以上動いたら配置キャンセル
const PREVIEW_OFFSET_Y = -6;

const canvas = document.getElementById('gc');
const ctx    = canvas.getContext('2d');
let U = 20;
let BASE_U = 20;
const ZOOM_MIN = 0.4;
const ZOOM_MAX = 4.0;
let zoomLevel = 1.0;

// ===== 初期化 =====
function init() {
  const wrap = document.getElementById('canvas-wrap');
  const aw = wrap.clientWidth - 12;
  const ah = wrap.clientHeight - 12;
  BASE_U = Math.max(3, Math.min(8, Math.floor(Math.min(aw/GRID_COLS, ah/GRID_ROWS))));
  U = Math.round(BASE_U * zoomLevel);
  canvas.width  = GRID_COLS * U;
  canvas.height = GRID_ROWS * U;
  redraw();
}

function applyZoom(delta, cx, cy) {
  const wrap = document.getElementById('canvas-wrap');
  const px = cx !== undefined ? cx : wrap.clientWidth/2;
  const py = cy !== undefined ? cy : wrap.clientHeight/2;
  const ratioX = (wrap.scrollLeft + px) / canvas.width;
  const ratioY = (wrap.scrollTop  + py) / canvas.height;

  zoomLevel = Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, zoomLevel * delta));
  U = Math.max(5, Math.round(BASE_U * zoomLevel));
  canvas.width  = GRID_COLS * U;
  canvas.height = GRID_ROWS * U;

  wrap.scrollLeft = canvas.width  * ratioX - px;
  wrap.scrollTop  = canvas.height * ratioY - py;
  document.getElementById('zoom-label').textContent = Math.round(zoomLevel*100)+'%';
  redraw();
}

// ===== ユーティリティ =====
function toU(mm) { return mm / BASE_MM; }

function blockSize(b) {
  return b.rotated
    ? {cols: toU(b.spanMM),  rows: toU(b.widthMM)}
    : {cols: toU(b.widthMM), rows: toU(b.spanMM)};
}

function isBlockAt(b, col, row) {
  const {cols,rows} = blockSize(b);
  return col>=b.col && col<b.col+cols && row>=b.row && row<b.row+rows;
}

// ===== 描画 =====
function redraw() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  ctx.fillStyle='#0a0c12';
  ctx.fillRect(0,0,canvas.width,canvas.height);

  // 細グリッド（305mm単位）
  ctx.strokeStyle='#111620'; ctx.lineWidth=0.5;
  for(let c=0;c<=GRID_COLS;c++){ctx.beginPath();ctx.moveTo(c*U,0);ctx.lineTo(c*U,canvas.height);ctx.stroke();}
  for(let r=0;r<=GRID_ROWS;r++){ctx.beginPath();ctx.moveTo(0,r*U);ctx.lineTo(canvas.width,r*U);ctx.stroke();}

  // 中グリッド（610mm = 2マス）
  ctx.strokeStyle='#191f30'; ctx.lineWidth=0.8;
  for(let c=0;c<=GRID_COLS;c+=2){ctx.beginPath();ctx.moveTo(c*U,0);ctx.lineTo(c*U,canvas.height);ctx.stroke();}
  for(let r=0;r<=GRID_ROWS;r+=2){ctx.beginPath();ctx.moveTo(0,r*U);ctx.lineTo(canvas.width,r*U);ctx.stroke();}

  // 太グリッド（1829mm ≈ 6マス）
  ctx.strokeStyle='#1e2840'; ctx.lineWidth=1.2;
  for(let c=0;c<=GRID_COLS;c+=6){ctx.beginPath();ctx.moveTo(c*U,0);ctx.lineTo(c*U,canvas.height);ctx.stroke();}
  for(let r=0;r<=GRID_ROWS;r+=6){ctx.beginPath();ctx.moveTo(0,r*U);ctx.lineTo(canvas.width,r*U);ctx.stroke();}

  // 確定済みブロック
  blocks.forEach(b => drawBlock(b, 1.0, false));


  // プレビュー（配置ツールのみ）
  if (previewPos && tool==='draw') {
    const dummy = {col:previewPos.col, row:previewPos.row, widthMM:currentWidth, spanMM:currentSpan, rotated:isRotated};
    drawBlock(dummy, 0.4, true);
  }

  updateStats();
}

function drawBlock(b, alpha, dashed) {
  const col = SPAN_COLORS[b.spanMM] || SPAN_COLORS[1829];
  const {cols,rows} = blockSize(b);
  const x=b.col*U, y=b.row*U, w=cols*U, h=rows*U;
  const pad=Math.max(1,U*0.05);
  const lw=Math.max(1,U*0.08);

  ctx.save();
  ctx.globalAlpha = alpha;

  // 塗り
  ctx.fillStyle = col.fill;
  ctx.fillRect(x+pad,y+pad,w-pad*2,h-pad*2);

  // ブレス
  ctx.strokeStyle = col.line+'55';
  ctx.lineWidth = lw*0.7;
  ctx.setLineDash([]);
  ctx.beginPath(); ctx.moveTo(x+pad*2,y+pad*2); ctx.lineTo(x+w-pad*2,y+h-pad*2); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x+w-pad*2,y+pad*2); ctx.lineTo(x+pad*2,y+h-pad*2); ctx.stroke();

  // 外枠
  ctx.strokeStyle = col.line;
  ctx.lineWidth = lw*1.3;
  if (dashed) ctx.setLineDash([4,3]);
  else        ctx.setLineDash([]);
  ctx.strokeRect(x+pad,y+pad,w-pad*2,h-pad*2);
  ctx.setLineDash([]);

  // ラベル（幅×スパン）
  const fs = Math.max(6, Math.min(11, Math.min(w,h)*0.28));
  if (w>20 && h>12) {
    ctx.fillStyle = col.line+'cc';
    ctx.font = fs+'px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(b.widthMM+'×'+b.spanMM, x+w/2, y+h/2+fs*0.35);
  }

  // 横置きマーク
  if (b.rotated && w>16 && h>16) {
    ctx.fillStyle = col.line+'bb';
    ctx.font = Math.max(7,U*0.38)+'px monospace';
    ctx.textAlign = 'right';
    ctx.fillText('↔', x+w-pad*2, y+pad*2+U*0.38);
  }

  ctx.restore();
}

// ===== ポインタ操作 =====
function getRaw(cx,cy) {
  const r = canvas.getBoundingClientRect();
  return {col:Math.floor((cx-r.left)/U), row:Math.floor((cy-r.top)/U)};
}

function getSnapped(cx,cy) {
  const raw = getRaw(cx,cy);
  // 100mm単位でスナップ（そのままグリッド位置がスナップ位置）
  return {col: raw.col, row: raw.row};
}

function onDown(cx,cy) {
  isDown = true;
  lastUpPos = {x:cx, y:cy};
  dragStartPos = {x:cx, y:cy};
  if (tool==='draw') {
    const s = getSnapped(cx, cy);
    previewPos = {col: s.col, row: s.row + PREVIEW_OFFSET_Y};
  }
  redraw();
}

function onMove(cx,cy) {
  if (!isDown) return;
  lastUpPos = {x:cx, y:cy};
  if (tool==='draw') {
    const s = getSnapped(cx, cy);
    previewPos = {col: s.col, row: s.row + PREVIEW_OFFSET_Y};
    redraw();
  }
}

function onUp(cx,cy) {
  if (!isDown) return;
  isDown = false;
  previewPos = null;
  panStart = null;

  const moved = dragStartPos
    ? Math.hypot(cx - dragStartPos.x, cy - dragStartPos.y)
    : 0;
  dragStartPos = null;

  if (tool==='draw' && moved < DRAG_THRESHOLD) {
    saveHistory();
    const s = getSnapped(cx, cy);
    const snapped = {col: s.col, row: s.row + PREVIEW_OFFSET_Y};
    blocks.push({col:snapped.col, row:snapped.row, widthMM:currentWidth, spanMM:currentSpan, rotated:isRotated});
  } else if (tool==='erase' && moved < DRAG_THRESHOLD) {
    saveHistory();
    const raw = getRaw(cx,cy);
    blocks = blocks.filter(b => !isBlockAt(b, raw.col, raw.row));
  }
  redraw();
}

// マウス
canvas.addEventListener('mousedown', e => { if(tool==='move') canvas.style.cursor='grabbing'; onDown(e.clientX, e.clientY); });
canvas.addEventListener('mousemove', e => onMove(e.clientX, e.clientY));
window.addEventListener('mouseup',   e => { if(tool==='move') canvas.style.cursor='grab'; if(isDown) onUp(e.clientX, e.clientY); });

// マウスホイールズーム
document.getElementById('canvas-wrap').addEventListener('wheel', e => {
  e.preventDefault();
  const rect = canvas.getBoundingClientRect();
  applyZoom(e.deltaY < 0 ? 1.15 : 1/1.15, e.clientX - rect.left, e.clientY - rect.top);
}, {passive:false});

// タッチ（1本指=配置/消去、2本指=移動orピンチズーム）
let lastPinchDist = null;
let lastPanPos = null;   // 2本指パン用
let wasPinching = false;

canvas.addEventListener('touchstart', e => {
  e.preventDefault();
  if (e.touches.length === 1) {
    lastPinchDist = null;
    lastPanPos = null;
    const t = e.touches[0];
    onDown(t.clientX, t.clientY);
  } else if (e.touches.length === 2) {
    // 2本指：配置キャンセル、パン＋ピンチ開始
    isDown = false; previewPos = null; dragStartPos = null; wasPinching = true; redraw();
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    lastPinchDist = Math.hypot(dx, dy);
    lastPanPos = {
      x: (e.touches[0].clientX + e.touches[1].clientX) / 2,
      y: (e.touches[0].clientY + e.touches[1].clientY) / 2
    };
  }
}, {passive:false});

canvas.addEventListener('touchmove', e => {
  e.preventDefault();
  if (e.touches.length === 1 && !lastPinchDist) {
    const t = e.touches[0];
    onMove(t.clientX, t.clientY);
  } else if (e.touches.length === 2) {
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    const dist = Math.hypot(dx, dy);
    const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
    const midY = (e.touches[0].clientY + e.touches[1].clientY) / 2;

    const wrap = document.getElementById('canvas-wrap');

    // パン（2本指移動）
    if (lastPanPos) {
      wrap.scrollLeft -= midX - lastPanPos.x;
      wrap.scrollTop  -= midY - lastPanPos.y;
    }

    // ピンチズーム
    if (lastPinchDist && Math.abs(dist - lastPinchDist) > 1) {
      const rect = canvas.getBoundingClientRect();
      const cx = midX - rect.left;
      const cy = midY - rect.top;
      applyZoom(dist / lastPinchDist, cx, cy);
    }

    lastPinchDist = dist;
    lastPanPos = {x: midX, y: midY};
  }
}, {passive:false});

canvas.addEventListener('touchend', e => {
  e.preventDefault();
  if (e.touches.length === 0) {
    if (!wasPinching && isDown && lastUpPos) onUp(lastUpPos.x, lastUpPos.y);
    lastPinchDist = null; lastPanPos = null; wasPinching = false;
    isDown = false; previewPos = null; dragStartPos = null; redraw();
  } else if (e.touches.length === 1) {
    lastPinchDist = null; lastPanPos = null;
    if (wasPinching) { wasPinching = false; isDown = false; previewPos = null; redraw(); }
  }
}, {passive:false});

// ===== コントロール =====
function setTool(t) {
  tool = t;
  document.getElementById('btn-draw').className  = t==='draw'  ? 'tbtn at' : 'tbtn';
  document.getElementById('btn-erase').className = t==='erase' ? 'tbtn et' : 'tbtn';
  previewPos = null; panStart = null;
  redraw();
}

function setRotate(rotated) {
  isRotated = rotated;
  document.getElementById('rot-tate').className = !rotated ? 'tbtn mt' : 'tbtn';
  document.getElementById('rot-yoko').className =  rotated ? 'tbtn mt' : 'tbtn';
  updateSub();
}

function setWidth(w) {
  currentWidth = w;
  WIDTH_OPTIONS.forEach(v => document.getElementById('w-'+v).className = v===w ? 'tbtn aw' : 'tbtn');
  updateSub();
}

function setSpan(s) {
  currentSpan = s;
  SPAN_OPTIONS.forEach(v => document.getElementById('s-'+v).className = v===s ? 'tbtn as' : 'tbtn');
  updateSub();
}

function updateSub() {
  document.getElementById('header-sub').textContent =
    '幅: '+currentWidth+'mm / スパン: '+currentSpan+'mm / '+(isRotated?'横置き':'縦置き');
}

function resetZoom() {
  zoomLevel = 1.0;
  U = BASE_U;
  canvas.width  = GRID_COLS * U;
  canvas.height = GRID_ROWS * U;
  document.getElementById('zoom-label').textContent = '100%';
  redraw();
}

function setMode(m) {
  mode = m;
  document.getElementById('mode-first').classList.toggle('active', m==='first');
  document.getElementById('mode-cont').classList.toggle('active',  m==='cont');
}

function clearAll() {
  saveHistory();
  blocks = [];
  previewPos = null;
  redraw();
}

// ===== 統計 =====
function updateStats() {
  const total = blocks.reduce((s,b)=>s+b.spanMM,0);
  document.getElementById('stat-cells').textContent = blocks.length;
  document.getElementById('stat-spans').textContent = Math.round(total/1829);
  document.getElementById('stat-len').textContent   = total.toLocaleString();
}

// ===== アンドゥ・リドゥ =====
function saveHistory() {
  undoStack.push(JSON.stringify(blocks));
  redoStack = [];
  updateUndoButtons();
}

function undo() {
  if (undoStack.length === 0) return;
  redoStack.push(JSON.stringify(blocks));
  blocks = JSON.parse(undoStack.pop());
  updateUndoButtons();
  redraw();
}

function redo() {
  if (redoStack.length === 0) return;
  undoStack.push(JSON.stringify(blocks));
  blocks = JSON.parse(redoStack.pop());
  updateUndoButtons();
  redraw();
}

function updateUndoButtons() {
  document.getElementById('btn-undo').className = undoStack.length > 0 ? 'tbtn' : 'tbtn disabled';
  document.getElementById('btn-redo').className = redoStack.length > 0 ? 'tbtn' : 'tbtn disabled';
}

// ===== メニュー =====
const COLOR_PALETTE = [
  // 赤・ピンク系
  '#ff6b6b','#ff9ee0','#ef476f','#e76f51',
  // オレンジ・黄系
  '#ff8c00','#f4a100','#ffd93d','#ffd166',
  // 緑系
  '#6bcb77','#06d6a0','#00cc88','#264653',
  // 青・水色系
  '#00d4ff','#00b4d8','#118ab2','#073b4c',
  // 紫・グレー系
  '#a259ff','#aaaaaa',
];

function openSaveTab() { openMenu(); switchTab('save'); }

function openMenu() {
  buildColorSettings();
  buildLegendInfo();
  buildSavedList();
  document.getElementById('menu-overlay').classList.add('visible');
}
function closeMenu() {
  document.getElementById('menu-overlay').classList.remove('visible');
}
function closeMenuOverlay(e) {
  if (e.target === document.getElementById('menu-overlay')) closeMenu();
}

const TABS = ['color','save','info','updates','privacy','contact'];
function switchTab(tab) {
  TABS.forEach(t => {
    document.getElementById('content-'+t).style.display = t===tab ? '' : 'none';
    document.getElementById('tab-'+t).classList.toggle('active', t===tab);
  });
  if (tab==='save') buildSavedList();
}

const COLOR_GROUPS = [
  { label: '赤・ピンク', colors: ['#ff6b6b','#ff9ee0','#ef476f','#e76f51'] },
  { label: 'オレンジ・黄', colors: ['#ff8c00','#f4a100','#ffd93d','#ffd166'] },
  { label: '緑', colors: ['#6bcb77','#06d6a0','#00cc88','#22cc44'] },
  { label: '青・水色', colors: ['#00d4ff','#00b4d8','#118ab2','#4477ff'] },
  { label: '紫・グレー', colors: ['#a259ff','#cc44ff','#aaaaaa','#ffffff'] },
];

function buildColorSettings() {
  const el = document.getElementById('color-settings');
  el.innerHTML = SPAN_OPTIONS.map(s => {
    const cur = SPAN_COLORS[s].line;
    const swatches = COLOR_GROUPS.map(g =>
      g.colors.map(c =>
        '<div class="cswatch'+(c===cur?' sel':'')+'" style="background:'+c+';" onclick="applyColor('+s+',\''+c+'\')"></div>'
      ).join('')
    ).join('');
    return '<div class="color-row-wrap">'+
      '<div class="color-row-header">'+
        '<div class="color-row-label">スパン '+s+'mm</div>'+
        '<div class="color-cur-dot" style="background:'+cur+';border-color:'+cur+';">現在</div>'+
      '</div>'+
      '<div class="cgroup-swatches" style="flex-wrap:wrap;">'+swatches+'</div>'+
      '</div>';
  }).join('');
}

function buildLegendInfo() {
  const el = document.getElementById('legend-info');
  el.innerHTML = SPAN_OPTIONS.map(s => {
    const c = SPAN_COLORS[s].line;
    return '<div class="legend-info-row"><div class="legend-info-dot" style="background:'+c+'33;border-color:'+c+';"></div>スパン '+s+'mm</div>';
  }).join('');
}

function applyColor(spanMM, color) {
  SPAN_COLORS[spanMM] = { line: color, fill: color + '18' };
  updateLegend();
  buildColorSettings();
  redraw();
}

function updateLegend() {
  SPAN_OPTIONS.forEach(s => {
    const c = SPAN_COLORS[s].line;
    const dot = document.getElementById('legend-dot-' + s);
    if (dot) { dot.style.background = c + '33'; dot.style.borderColor = c; }
  });
}

// ===== 保存・読み込み =====
const STORAGE_KEY = 'ashiba_drawings';

function getSavedDrawings() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
  catch(e) { return []; }
}

function saveDrawing() {
  const title = document.getElementById('save-title').value.trim();
  if (!title) { alert('タイトルを入力してください'); return; }
  if (blocks.length === 0) { alert('図面が空です'); return; }

  const drawings = getSavedDrawings();
  const now = new Date();
  const dateStr = now.getFullYear()+'/'+(now.getMonth()+1).toString().padStart(2,'0')+'/'+now.getDate().toString().padStart(2,'0');

  const existing = drawings.findIndex(d => d.title === title);
  if (existing >= 0) {
    if (!confirm('「'+title+'」はすでに保存されています。上書きしますか？')) return;
    drawings[existing] = { title, date: dateStr, blocks: JSON.parse(JSON.stringify(blocks)) };
  } else {
    drawings.unshift({ title, date: dateStr, blocks: JSON.parse(JSON.stringify(blocks)) });
  }

  localStorage.setItem(STORAGE_KEY, JSON.stringify(drawings));
  document.getElementById('save-title').value = '';
  buildSavedList();
  const btn = document.querySelector('.save-btn');
  btn.textContent = '✓ 完了';
  btn.style.background = '#22cc88';
  setTimeout(() => { btn.textContent = '保存'; btn.style.background = ''; }, 1500);
}

function loadDrawingByIndex(i) {
  const drawings = getSavedDrawings();
  const d = drawings[i];
  if (!d) return;
  saveHistory();
  blocks = JSON.parse(JSON.stringify(d.blocks));
  closeMenu();
  redraw();
}

function deleteDrawingByIndex(i) {
  const drawings = getSavedDrawings();
  drawings.splice(i, 1);
  localStorage.setItem(STORAGE_KEY, JSON.stringify(drawings));
  buildSavedList();
}

function confirmDelete(i) {
  const drawings = getSavedDrawings();
  const item = document.getElementById('saved-item-' + i);
  if (!item) return;
  item.innerHTML =
    '<div class="saved-item-info"><div class="saved-item-title" style="color:var(--danger);">「'+drawings[i].title+'」を削除しますか？</div></div>'+
    '<div class="saved-item-btns">'+
    '<button class="del-btn" style="background:var(--danger);color:#fff;" onclick="deleteDrawingByIndex('+i+')">削除する</button>'+
    '<button class="load-btn" style="background:var(--surface2);color:var(--text);" onclick="buildSavedList()">キャンセル</button>'+
    '</div>';
}

function buildSavedList() {
  const drawings = getSavedDrawings();
  const el = document.getElementById('saved-list');
  if (!el) return;
  if (drawings.length === 0) {
    el.innerHTML = '<div class="saved-empty">保存された図面はありません</div>';
    return;
  }
  el.innerHTML = drawings.map((d, i) =>
    '<div class="saved-item" id="saved-item-'+i+'">'+
    '<div class="saved-item-info">'+
    '<div class="saved-item-title">'+d.title+'</div>'+
    '<div class="saved-item-date">📅 '+d.date+'</div>'+
    '<div class="saved-item-blocks">🧱 '+d.blocks.length+' ブロック</div>'+
    '</div>'+
    '<div class="saved-item-btns">'+
    '<button class="load-btn" onclick="loadDrawingByIndex('+i+')">読込</button>'+
    '<button class="del-btn" onclick="confirmDelete('+i+')">削除</button>'+
    '</div></div>'
  ).join('');
}

window.addEventListener('resize',init);
init();
</script>
</body>
</html>
