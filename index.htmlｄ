// ===== 人工計算 =====
let kumiRatio = 6; // デフォルト6:4

function changeRatio(d) {
  kumiRatio = Math.min(9, Math.max(1, kumiRatio + d));
  const kaiRatio = 10 - kumiRatio;
  document.getElementById('ratio-kumi').textContent = kumiRatio;
  document.getElementById('ratio-kai').textContent  = kaiRatio;
  calcNinku();
}

function calcNinku() {
  const sqm   = parseFloat(document.getElementById('calc-sqm').value);
  const tanka = parseFloat(document.getElementById('calc-tanka').value);
  const joyo  = parseFloat(document.getElementById('calc-joyo').value);

  if (!sqm || !tanka || !joyo) {
    document.getElementById('calc-result').style.display = 'none';
    return;
  }

  const kumiPct = kumiRatio / 10;
  const kaiPct  = (10 - kumiRatio) / 10;

  const koji  = sqm * tanka;
  const total = koji / joyo;
  const kumi  = total * kumiPct;
  const kai   = total * kaiPct;

  document.getElementById('res-koji').textContent    = '¥' + Math.round(koji).toLocaleString();
  document.getElementById('res-total').textContent   = total.toFixed(2) + ' 人工';
  document.getElementById('res-kumi').textContent    = kumi.toFixed(2) + ' 人工';
  document.getElementById('res-kai').textContent     = kai.toFixed(2) + ' 人工';
  document.getElementById('res-kumi-pct').textContent = kumiRatio * 10;
  document.getElementById('res-kai-pct').textContent  = (10 - kumiRatio) * 10;
  document.getElementById('calc-result').style.display = 'block';
  document.getElementById('reflect-btn').style.display = 'block';
}

function resetCalc() {
  document.getElementById('calc-sqm').value   = '';
  document.getElementById('calc-tanka').value = '';
  document.getElementById('calc-joyo').value  = '';
  document.getElementById('calc-result').style.display = 'none';
  document.getElementById('reflect-btn').style.display = 'none';
  kumiRatio = 6;
  document.getElementById('ratio-kumi').textContent = 6;
  document.getElementById('ratio-kai').textContent  = 4;
}

function reflectToProgress() {
  const sqm   = parseFloat(document.getElementById('calc-sqm').value);
  const tanka = parseFloat(document.getElementById('calc-tanka').value);
  const joyo  = parseFloat(document.getElementById('calc-joyo').value);
  if (!sqm || !tanka || !joyo) return;

  // 人工管理タブに切り替え
  switchTab('progress');

  // フォームに値をセット
  document.getElementById('prog-sqm').value   = sqm;
  document.getElementById('prog-tanka').value = tanka;
  document.getElementById('prog-joyo').value  = joyo;
  document.getElementById('site-ratio-kumi').textContent = kumiRatio;
  document.getElementById('site-ratio-kai').textContent  = 10 - kumiRatio;
  siteRatio = kumiRatio;
  document.getElementById('prog-add-form').style.display = 'block';
  calcSiteTarget();
  document.getElementById('prog-add-form').scrollIntoView({behavior:'smooth'});
}

