function resetZoom() {
  const wrap = document.getElementById('canvas-wrap');

  if (blocks.length > 0) {
    // ブロックの範囲を計算
    let minC=Infinity, minR=Infinity, maxC=-Infinity, maxR=-Infinity;
    blocks.forEach(b => {
      const {cols,rows} = blockSize(b);
      minC = Math.min(minC, b.col);
      minR = Math.min(minR, b.row);
      maxC = Math.max(maxC, b.col + cols);
      maxR = Math.max(maxR, b.row + rows);
    });
    // 余白を持たせる
    const pad = 3;
    minC -= pad; minR -= pad; maxC += pad; maxR += pad;
    const spanC = maxC - minC;
    const spanR = maxR - minR;

    // 画面に収まるズームを計算
    const aw = wrap.clientWidth  - 12;
    const ah = wrap.clientHeight - 12;
    const newU = Math.max(0.5, Math.floor(Math.min(aw/spanC, ah/spanR)));
    zoomLevel = newU / BASE_U;
    U = newU;
    canvas.width  = Math.round(GRID_COLS * U);
    canvas.height = Math.round(GRID_ROWS * U);

    // ブロック中心にスクロール
    wrap.scrollLeft = minC * U - (aw - spanC * U) / 2;
    wrap.scrollTop  = minR * U - (ah - spanR * U) / 2;
  } else {
    // ブロックなし→中央に戻る
    zoomLevel = 1.0;
    U = BASE_U;
    canvas.width  = Math.round(GRID_COLS * U);
    canvas.height = Math.round(GRID_ROWS * U);
    wrap.scrollLeft = (canvas.width  - wrap.clientWidth)  / 2;
    wrap.scrollTop  = (canvas.height - wrap.clientHeight) / 2;
  }

  document.getElementById('zoom-label').textContent = Math.round(zoomLevel*100)+'%';
  redraw();
}

