// ===== メモ機能 =====
let memos    = [];  // {col, row, text, size}
let memoPos  = null;
let memoDrag = null;
// 足場板
let boards     = [];  // {col, row, spanMM, widthMM, angle, widthLabel}
let boardSpan  = 1829;
let boardWidth = 305;  // 実際のグリッド幅（305=表示250, 610=表示500）
let boardAngle = 0;

function applyMemo() {
  if (!memoPos) return;
  const text = document.getElementById('memo-input').value.trim();
  if (!text) return;
  const size = parseInt(document.getElementById('memo-size').value);
  saveHistory();
  memos.push({col: memoPos.col, row: memoPos.row, text, size});
  document.getElementById('memo-input').value = '';
  memoPos = null;
  redraw();
}

function cancelMemo() {
  memoPos = null;
  document.getElementById('memo-input').value = '';
  redraw();
}

function drawMemos() {
  memos.forEach((m, i) => {
    const x = m.col * U;
    const y = m.row * U;
    const fs = Math.max(8, m.size * (U/20));
    ctx.save();
    ctx.font = `bold ${fs}px 'Noto Sans JP', sans-serif`;
    // ドラッグ中は半透明
    ctx.globalAlpha = (memoDrag === i) ? 0.6 : 1.0;
    ctx.fillStyle = '#ffffff';
    ctx.strokeStyle = '#00000088';
    ctx.lineWidth = 3;
    ctx.textAlign = 'left';
    ctx.strokeText(m.text, x+2, y+fs);
    ctx.fillText(m.text, x+2, y+fs);
    // メモモード時はドラッグハンドル（●）を表示
    if (tool === 'memo') {
      ctx.fillStyle = '#22cc88';
      ctx.beginPath();
      ctx.arc(x, y+fs/2, Math.max(4, U*0.2), 0, Math.PI*2);
      ctx.fill();
    }
    // 消去モード時は×マークを表示
    if (tool === 'erase') {
      ctx.fillStyle = '#e03e3e';
      ctx.font = `bold ${Math.max(10,fs*0.8)}px monospace`;
      ctx.fillText('✕', x-2, y+fs*0.5);
    }
    ctx.restore();
  });
}

