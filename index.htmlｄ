    '<button onclick="deleteSiteCancel()" style="flex:1;padding:10px;background:var(--surface2);color:var(--text);border:1px solid var(--sep);border-radius:8px;font-size:13px;font-weight:700;font-family:\'Noto Sans JP\',sans-serif;cursor:pointer;">いいえ</button>'+
    '</div>';
