<script>
// ===== 定数 =====
const BASE_MM   = 101;  // グリッド最小単位 101mm（305の約1/3）
const GRID_COLS = 900;  // 900×101mm = 90,900mm（約91m）
const GRID_ROWS = 600;  // 600×101mm = 60,600mm（約61m）
const WIDTH_OPTIONS = [610,914,1219];
const SPAN_OPTIONS  = [610,914,1219,1524,1829];
const SPAN_COLORS  = {
  610:  {line:'#ff9ee0',fill:'#ff9ee010'},
  914:  {line:'#ffd93d',fill:'#ffd93d10'},
  1219: {line:'#6bcb77',fill:'#6bcb7710'},
  1524: {line:'#ff6b6b',fill:'#ff6b6b10'},
  1829: {line:'#00d4ff',fill:'#00d4ff10'},
};

// ===== 状態 =====
let blocks       = [];
let undoStack    = []; // 操作履歴
let redoStack    = []; // やり直し履歴
let tool         = 'draw';
let currentWidth = 914;
let currentSpan  = 1829;
let isRotated    = false;
// ブラケット
let currentBracketSize = 350;
let currentBracketSpan = 610;
const BRACKET_SIZES = [350, 500, 750, 1000];
// 表示サイズ→実際のグリッドサイズ（305mm単位）への変換
const BRACKET_SIZE_MAP = {
  350:  303,   // 3グリッド（303mm）
  500:  505,   // 5グリッド（505mm）
  750:  707,   // 7グリッド（707mm）
  1000: 1010,  // 10グリッド（1010mm）
};
const BRACKET_COLOR = { line: '#ff8c00', fill: '#ff8c0020' };

// ポインタ状態
let isDown    = false;
let lastUpPos = null;
let previewPos = null;
let panStart  = null;
let dragStartPos = null; // ドラッグ開始位置（誤操作防止用）
const DRAG_THRESHOLD = 80; // この距離(px)以上動いたら配置キャンセル
// プレビューを指の上に表示（px単位で150px上）
function previewOffset() { return -Math.ceil(150 / U); }

const canvas = document.getElementById('gc');
const ctx    = canvas.getContext('2d');
let U = 20;
let BASE_U = 20;
const ZOOM_MIN = 0.1;
const ZOOM_MAX = 8.0;
let zoomLevel = 1.0;

// ===== 初期化 =====
function init() {
  const wrap = document.getElementById('canvas-wrap');
  const aw = wrap.clientWidth - 12;
  const ah = wrap.clientHeight - 12;
  BASE_U = Math.max(3, Math.min(32, Math.floor(Math.min(aw/GRID_COLS, ah/GRID_ROWS) * 4)));
  U = BASE_U * zoomLevel;
  canvas.width  = Math.round(GRID_COLS * U);
  canvas.height = Math.round(GRID_ROWS * U);
  // 初期表示をキャンバス中央にスクロール
  wrap.scrollLeft = (canvas.width  - aw) / 2;
  wrap.scrollTop  = (canvas.height - ah) / 2;
  document.getElementById('zoom-label').textContent = Math.round(zoomLevel*100)+'%';
  redraw();
}

function applyZoom(delta, cx, cy) {
  const wrap = document.getElementById('canvas-wrap');
  const px = cx !== undefined ? cx : wrap.clientWidth/2;
  const py = cy !== undefined ? cy : wrap.clientHeight/2;
  const ratioX = (wrap.scrollLeft + px) / canvas.width;
  const ratioY = (wrap.scrollTop  + py) / canvas.height;

  zoomLevel = Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, zoomLevel * delta));
  U = Math.max(0.5, BASE_U * zoomLevel);
  canvas.width  = Math.round(GRID_COLS * U);
  canvas.height = Math.round(GRID_ROWS * U);

  wrap.scrollLeft = canvas.width  * ratioX - px;
  wrap.scrollTop  = canvas.height * ratioY - py;
  document.getElementById('zoom-label').textContent = Math.round(zoomLevel*100)+'%';

  // ブロックがある場合、ブロックが画面から完全に外れないよう補正
  if (blocks.length > 0) {
    let minC=Infinity, minR=Infinity, maxC=-Infinity, maxR=-Infinity;
    blocks.forEach(b => {
      const {cols,rows} = blockSize(b);
      minC = Math.min(minC, b.col);
      minR = Math.min(minR, b.row);
      maxC = Math.max(maxC, b.col + cols);
      maxR = Math.max(maxR, b.row + rows);
    });
    const bLeft   = minC * U;
    const bRight  = maxC * U;
    const bTop    = minR * U;
    const bBottom = maxR * U;
    const aw = wrap.clientWidth;
    const ah = wrap.clientHeight;
    const margin = U * 2;

    // ブロックが完全に画面外に出ないよう制限
    if (wrap.scrollLeft > bRight - margin)  wrap.scrollLeft = bRight - margin;
    if (wrap.scrollLeft + aw < bLeft + margin) wrap.scrollLeft = bLeft + margin - aw;
    if (wrap.scrollTop  > bBottom - margin) wrap.scrollTop  = bBottom - margin;
    if (wrap.scrollTop  + ah < bTop + margin)  wrap.scrollTop  = bTop + margin - ah;
  }

  redraw();
}

// ===== ユーティリティ =====
function toU(mm) { return mm / BASE_MM; }

function blockSize(b) {
  return b.rotated
    ? {cols: toU(b.spanMM),  rows: toU(b.widthMM)}
    : {cols: toU(b.widthMM), rows: toU(b.spanMM)};
}

function isBlockAt(b, col, row) {
  const {cols,rows} = blockSize(b);
  return col>=b.col && col<b.col+cols && row>=b.row && row<b.row+rows;
}

// ===== 描画 =====
function redraw() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  ctx.fillStyle='#0a0c12';
  ctx.fillRect(0,0,canvas.width,canvas.height);

  // グリッド描画（表示範囲のみ）
  const wrap2 = document.getElementById('canvas-wrap');
  const startC = Math.max(0, Math.floor(wrap2.scrollLeft / U) - 1);
  const endC   = Math.min(GRID_COLS, Math.ceil((wrap2.scrollLeft + wrap2.clientWidth)  / U) + 1);
  const startR = Math.max(0, Math.floor(wrap2.scrollTop  / U) - 1);
  const endR   = Math.min(GRID_ROWS, Math.ceil((wrap2.scrollTop  + wrap2.clientHeight) / U) + 1);

  // 細グリッド（101mm単位）
  ctx.strokeStyle='#111620'; ctx.lineWidth=0.5;
  ctx.beginPath();
  for(let c=startC;c<=endC;c++){ctx.moveTo(c*U,startR*U);ctx.lineTo(c*U,endR*U);}
  for(let r=startR;r<=endR;r++){ctx.moveTo(startC*U,r*U);ctx.lineTo(endC*U,r*U);}
  ctx.stroke();

  // 中グリッド（606mm ≈ 6マス）
  ctx.strokeStyle='#191f30'; ctx.lineWidth=0.8;
  ctx.beginPath();
  for(let c=Math.floor(startC/6)*6;c<=endC;c+=6){ctx.moveTo(c*U,startR*U);ctx.lineTo(c*U,endR*U);}
  for(let r=Math.floor(startR/6)*6;r<=endR;r+=6){ctx.moveTo(startC*U,r*U);ctx.lineTo(endC*U,r*U);}
  ctx.stroke();

  // 太グリッド（1818mm ≈ 18マス）
  ctx.strokeStyle='#1e2840'; ctx.lineWidth=1.2;
  ctx.beginPath();
  for(let c=Math.floor(startC/18)*18;c<=endC;c+=18){ctx.moveTo(c*U,startR*U);ctx.lineTo(c*U,endR*U);}
  for(let r=Math.floor(startR/18)*18;r<=endR;r+=18){ctx.moveTo(startC*U,r*U);ctx.lineTo(endC*U,r*U);}
  ctx.stroke();

  // 確定済みブロック
  blocks.forEach(b => drawBlock(b, 1.0, false));

  // 足場板描画
  boards.forEach(b => drawBoard(b, 1.0));
  drawBoardPreview();


  // プレビュー（配置・ブラケットツール）
  if (previewPos && tool==='draw') {
    const dummy = {col:previewPos.col, row:previewPos.row, widthMM:currentWidth, spanMM:currentSpan, rotated:isRotated};
    drawBlock(dummy, 0.4, true);
  }
  if (previewPos && tool==='bracket') {
    const actualSize = BRACKET_SIZE_MAP[currentBracketSize] || currentBracketSize;
    const dummy = {col:previewPos.col, row:previewPos.row, widthMM:actualSize, spanMM:currentBracketSpan, rotated:isRotated, isBracket:true, bkLabel:currentBracketSize};
    drawBlock(dummy, 0.4, true);
  }

  // メモ描画
  drawMemos();

  // ピンチ中心インジケーター
  if (pinchCenter) {
    const wrap3 = document.getElementById('canvas-wrap');
    const px = pinchCenter.x;
    const py = pinchCenter.y;
    const r = 18;
    ctx.save();
    ctx.strokeStyle = '#ffffff88';
    ctx.lineWidth = 1.5;
    // 円
    ctx.beginPath();
    ctx.arc(px, py, r, 0, Math.PI*2);
    ctx.stroke();
    // 十字
    ctx.beginPath();
    ctx.moveTo(px-r*0.6, py); ctx.lineTo(px+r*0.6, py);
    ctx.moveTo(px, py-r*0.6); ctx.lineTo(px, py+r*0.6);
    ctx.stroke();
    ctx.restore();
  }

  updateStats();
}

function drawBlock(b, alpha, dashed) {
  const col = b.isBracket ? BRACKET_COLOR : (SPAN_COLORS[b.spanMM] || SPAN_COLORS[1829]);
  const {cols,rows} = blockSize(b);
  const x=b.col*U, y=b.row*U, w=cols*U, h=rows*U;
  const pad=Math.max(1,U*0.05);
  const lw=Math.max(1,U*0.08);

  ctx.save();
  ctx.globalAlpha = alpha;

  if (b.isBracket) {
    // ブラケット専用描画：斜線ハッチング
    ctx.fillStyle = col.fill;
    ctx.fillRect(x+pad,y+pad,w-pad*2,h-pad*2);
    ctx.strokeStyle = col.line;
    ctx.lineWidth = lw;
    if (dashed) ctx.setLineDash([4,3]);
    else        ctx.setLineDash([]);
    ctx.strokeRect(x+pad,y+pad,w-pad*2,h-pad*2);
    ctx.setLineDash([]);
    // 斜線（矩形内にclip）
    ctx.save();
    ctx.beginPath();
    ctx.rect(x+pad, y+pad, w-pad*2, h-pad*2);
    ctx.clip();
    ctx.strokeStyle = col.line+'88';
    ctx.lineWidth = lw*0.8;
    const step = Math.max(4, U*0.6);
    for (let i = -h; i < w+h; i += step) {
      ctx.beginPath();
      ctx.moveTo(x+pad+i, y+pad);
      ctx.lineTo(x+pad+i+h, y+h-pad);
      ctx.stroke();
    }
    ctx.restore();
    // BKラベル（元のサイズ表示）
    const fs = Math.max(8, Math.min(14, Math.min(w,h)*0.4));
    if (w>20 && h>10) {
      ctx.fillStyle = col.line;
      ctx.font = 'bold '+fs+'px monospace';
      ctx.textAlign = 'center';
      ctx.fillText('BK'+(b.bkLabel||b.widthMM), x+w/2, y+h/2+fs*0.35);
    }
  } else {
    // 通常ブロック描画
    ctx.fillStyle = col.fill;
    ctx.fillRect(x+pad,y+pad,w-pad*2,h-pad*2);

    ctx.strokeStyle = col.line+'55';
    ctx.lineWidth = lw*0.7;
    ctx.setLineDash([]);
    ctx.beginPath(); ctx.moveTo(x+pad*2,y+pad*2); ctx.lineTo(x+w-pad*2,y+h-pad*2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+w-pad*2,y+pad*2); ctx.lineTo(x+pad*2,y+h-pad*2); ctx.stroke();

    ctx.strokeStyle = col.line;
    ctx.lineWidth = lw*1.3;
    if (dashed) ctx.setLineDash([4,3]);
    else        ctx.setLineDash([]);
    ctx.strokeRect(x+pad,y+pad,w-pad*2,h-pad*2);
    ctx.setLineDash([]);

    const fs = Math.max(6, Math.min(11, Math.min(w,h)*0.28));
    if (w>20 && h>12) {
      ctx.fillStyle = col.line+'cc';
      ctx.font = fs+'px monospace';
      ctx.textAlign = 'center';
      ctx.fillText(b.widthMM+'×'+b.spanMM, x+w/2, y+h/2+fs*0.35);
    }

    if (b.rotated && w>16 && h>16) {
      ctx.fillStyle = col.line+'bb';
      ctx.font = Math.max(7,U*0.38)+'px monospace';
      ctx.textAlign = 'right';
      ctx.fillText('↔', x+w-pad*2, y+pad*2+U*0.38);
    }

    // 建地丸（4角）
    if (!b.isBracket) {
      const r = Math.max(2, Math.min(5, U*0.22));
      ctx.fillStyle = dashed ? col.line+'99' : col.line;
      ctx.strokeStyle = '#0a0c12';
      ctx.lineWidth = Math.max(0.5, r*0.3);
      [[x, y],[x+w, y],[x, y+h],[x+w, y+h]].forEach(([cx2,cy2]) => {
        ctx.beginPath();
        ctx.arc(cx2, cy2, r, 0, Math.PI*2);
        ctx.fill();
        ctx.stroke();
      });
    }
  }

  // 離れ矢印表示（共通・プレビュー時は非表示）
  if (b.hanare != null && !dashed) {
    const hfs = Math.max(11, Math.min(16, U*0.7));
    const arrowLen = Math.max(24, Math.min(50, b.hanare / 305 * U * 1.5));
    const dir = b.hanareDir || 'a'; // 'a'=上/左, 'b'=下/右

    ctx.save();
    ctx.strokeStyle = '#00d4ff';
    ctx.fillStyle   = '#00d4ff';
    ctx.lineWidth   = 1.5;

    if (!b.rotated) {
      // 縦置き→横矢印（左または右）
      const ax = dir==='a' ? x - 4 - arrowLen : x + w + 4;
      const ay = y + pad;

      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(ax + arrowLen, ay);
      ctx.stroke();

      // 矢頭（左端）
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(ax+5, ay-4); ctx.lineTo(ax+5, ay+4);
      ctx.closePath(); ctx.fill();

      // 矢頭（右端）
      ctx.beginPath();
      ctx.moveTo(ax+arrowLen, ay);
      ctx.lineTo(ax+arrowLen-5, ay-4); ctx.lineTo(ax+arrowLen-5, ay+4);
      ctx.closePath(); ctx.fill();

      ctx.font = 'bold '+hfs+'px monospace';
      ctx.textAlign = 'center';
      ctx.fillText(b.hanare, ax + arrowLen/2, ay - 4);

    } else {
      // 横置き→縦矢印（上または下）
      const ax = x + w + 4;
      const ay = dir==='a' ? y - 4 - arrowLen : y + h + 4;

      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(ax, ay + arrowLen);
      ctx.stroke();

      // 矢頭（上端）
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(ax-4, ay+5); ctx.lineTo(ax+4, ay+5);
      ctx.closePath(); ctx.fill();

      // 矢頭（下端）
      ctx.beginPath();
      ctx.moveTo(ax, ay+arrowLen);
      ctx.lineTo(ax-4, ay+arrowLen-5); ctx.lineTo(ax+4, ay+arrowLen-5);
      ctx.closePath(); ctx.fill();

      ctx.font = 'bold '+hfs+'px monospace';
      ctx.textAlign = 'left';
      ctx.fillText(b.hanare, ax+7, ay + arrowLen/2 + hfs*0.35);
    }

    ctx.restore();
  }

  ctx.restore();
}

// ===== ポインタ操作 =====
function getRaw(cx,cy) {
  const r = canvas.getBoundingClientRect();
  return {col:Math.floor((cx-r.left)/U), row:Math.floor((cy-r.top)/U)};
}

function getSnapped(cx,cy) {
  const raw = getRaw(cx,cy);
  return {col: raw.col, row: raw.row};
}

// ブラケットを近くの足場ブロック端にスナップ
function snapBracketToBlock(raw, bkWidthMM, bkSpanMM, rotated) {
  // ブラケットのグリッドサイズ
  const bkCols = rotated ? Math.round(bkSpanMM / BASE_MM) : Math.round(bkWidthMM / BASE_MM);
  const bkRows = rotated ? Math.round(bkWidthMM / BASE_MM) : Math.round(bkSpanMM / BASE_MM);

  let bestCol = raw.col;
  let bestRow = raw.row;
  let bestDist = Infinity;

  // 通常ブロック（非BK）を対象に近い端を探す
  blocks.filter(b => !b.isBracket).forEach(b => {
    const {cols, rows} = blockSize(b);

    // ブラケットが隣接できる候補位置を列挙
    const candidates = [
      // 右に隣接
      {col: b.col + cols, row: b.row},
      // 左に隣接
      {col: b.col - bkCols, row: b.row},
      // 下に隣接
      {col: b.col, row: b.row + rows},
      // 上に隣接
      {col: b.col, row: b.row - bkRows},
    ];

    candidates.forEach(c => {
      const dist = Math.hypot(c.col - raw.col, c.row - raw.row);
      if (dist < bestDist) {
        bestDist = dist;
        bestCol = c.col;
        bestRow = c.row;
      }
    });
  });

  // スナップ範囲内（6グリッド以内）なら使う、遠ければそのまま
  if (bestDist <= 6) return {col: bestCol, row: bestRow};
  return raw;
}

function onDown(cx,cy) {
  isDown = true;
  lastUpPos = {x:cx, y:cy};
  dragStartPos = {x:cx, y:cy};
  if (tool==='draw' || tool==='bracket' || tool==='board') {
    const s = getSnapped(cx, cy);
    previewPos = {col: s.col, row: s.row + previewOffset()};
  } else if (tool==='memo') {
    // 既存メモのドラッグ開始を検出
    const raw = getRaw(cx, cy);
    const idx = memos.findIndex(m => Math.hypot(m.col - raw.col, m.row - raw.row) <= 3);
    if (idx >= 0) memoDrag = idx;
  }
  redraw();
}

function onMove(cx,cy) {
  if (!isDown) return;
  lastUpPos = {x:cx, y:cy};
  if (tool==='draw' || tool==='bracket' || tool==='board') {
    const s = getSnapped(cx, cy);
    previewPos = {col: s.col, row: s.row + previewOffset()};
    redraw();
  } else if (tool==='memo' && memoDrag !== null) {
    // メモをドラッグ移動
    const raw = getRaw(cx, cy);
    memos[memoDrag].col = raw.col;
    memos[memoDrag].row = raw.row;
    redraw();
  }
}

function onUp(cx,cy) {
  if (!isDown) return;
  isDown = false;
  previewPos = null;
  panStart = null;

  const moved = dragStartPos
    ? Math.hypot(cx - dragStartPos.x, cy - dragStartPos.y)
    : 0;
  dragStartPos = null;

  if (tool==='memo' && memoDrag !== null) {
    // ドラッグ移動完了
    saveHistory();
    memoDrag = null;
    redraw();
    return;
  }
  memoDrag = null;

  if (tool==='draw' && moved < DRAG_THRESHOLD) {
    saveHistory();
    const s = getSnapped(cx, cy);
    const snapped = {col: s.col, row: s.row + previewOffset()};
    blocks.push({col:snapped.col, row:snapped.row, widthMM:currentWidth, spanMM:currentSpan, rotated:isRotated});
  } else if (tool==='bracket' && moved < DRAG_THRESHOLD) {
    saveHistory();
    const s = getSnapped(cx, cy);
    const snapped = {col: s.col, row: s.row + previewOffset()};
    const actualSize = BRACKET_SIZE_MAP[currentBracketSize] || currentBracketSize;
    blocks.push({col:snapped.col, row:snapped.row, widthMM:actualSize, spanMM:currentBracketSpan, rotated:isRotated, isBracket:true, bkLabel:currentBracketSize});
  } else if (tool==='board' && moved < DRAG_THRESHOLD) {
    saveHistory();
    const s = getSnapped(cx, cy);
    boards.push({col: s.col, row: s.row + previewOffset(), spanMM: boardSpan, widthMM: boardWidth, angle: boardAngle});
  } else if (tool==='erase' && moved < DRAG_THRESHOLD) {
    saveHistory();
    const raw = getRaw(cx,cy);
    // ブロック消去
    blocks = blocks.filter(b => !isBlockAt(b, raw.col, raw.row));
    // メモ消去（2グリッド以内）
    memos  = memos.filter(m => Math.hypot(m.col - raw.col, m.row - raw.row) > 2);
    // 足場板消去（✕マーク＝始点付近をタップ）
    boards = boards.filter(b => Math.hypot(b.col - raw.col, b.row - raw.row) > 2);
  } else if (tool==='hanare' && moved < DRAG_THRESHOLD) {
    const raw = getRaw(cx,cy);
    const idx = blocks.findIndex(b => isBlockAt(b, raw.col, raw.row));
    if (idx >= 0) openHanarePanel(idx);
  } else if (tool==='memo' && moved < DRAG_THRESHOLD) {
    const raw = getRaw(cx,cy);
    memoPos = raw;
    document.getElementById('memo-input').focus();
  }
  redraw();
}

// マウス
canvas.addEventListener('mousedown', e => { if(tool==='move') canvas.style.cursor='grabbing'; onDown(e.clientX, e.clientY); });
canvas.addEventListener('mousemove', e => onMove(e.clientX, e.clientY));
window.addEventListener('mouseup',   e => { if(tool==='move') canvas.style.cursor='grab'; if(isDown) onUp(e.clientX, e.clientY); });

// マウスホイールズーム
document.getElementById('canvas-wrap').addEventListener('wheel', e => {
  e.preventDefault();
  const rect = canvas.getBoundingClientRect();
  applyZoom(e.deltaY < 0 ? 1.15 : 1/1.15, e.clientX - rect.left, e.clientY - rect.top);
}, {passive:false});

// タッチ（1本指=配置/消去、2本指=移動orピンチズーム）
let lastPinchDist = null;
let lastPanPos = null;
let wasPinching = false;
let pinchCenter = null; // ピンチ中心点（canvas座標）

canvas.addEventListener('touchstart', e => {
  e.preventDefault();
  if (e.touches.length === 1) {
    lastPinchDist = null;
    lastPanPos = null;
    const t = e.touches[0];
    onDown(t.clientX, t.clientY);
  } else if (e.touches.length === 2) {
    // 2本指：配置キャンセル、パン＋ピンチ開始
    isDown = false; previewPos = null; dragStartPos = null; wasPinching = true; redraw();
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    lastPinchDist = Math.hypot(dx, dy);
    lastPanPos = {
      x: (e.touches[0].clientX + e.touches[1].clientX) / 2,
      y: (e.touches[0].clientY + e.touches[1].clientY) / 2
    };
  }
}, {passive:false});

canvas.addEventListener('touchmove', e => {
  e.preventDefault();
  if (e.touches.length === 1 && !lastPinchDist) {
    const t = e.touches[0];
    onMove(t.clientX, t.clientY);
  } else if (e.touches.length === 2) {
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    const dist = Math.hypot(dx, dy);
    const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
    const midY = (e.touches[0].clientY + e.touches[1].clientY) / 2;

    const wrap = document.getElementById('canvas-wrap');

    // パン（2本指移動）
    if (lastPanPos) {
      wrap.scrollLeft -= midX - lastPanPos.x;
      wrap.scrollTop  -= midY - lastPanPos.y;
    }

    // ピンチズーム
    if (lastPinchDist && Math.abs(dist - lastPinchDist) > 2) {
      const rect = canvas.getBoundingClientRect();
      const cx = midX - rect.left;
      const cy = midY - rect.top;
      pinchCenter = {x: cx, y: cy};
      const rawRatio = dist / lastPinchDist;
      // 変化を0.6倍に抑えて急激なズームを防ぐ
      const smoothRatio = rawRatio > 1
        ? 1 + (rawRatio - 1) * 0.6
        : 1 - (1 - rawRatio) * 0.6;
      applyZoom(smoothRatio, cx, cy);
    }

    lastPinchDist = dist;
    lastPanPos = {x: midX, y: midY};
  }
}, {passive:false});

canvas.addEventListener('touchend', e => {
  e.preventDefault();
  if (e.touches.length === 0) {
    if (!wasPinching && isDown && lastUpPos) onUp(lastUpPos.x, lastUpPos.y);
    lastPinchDist = null; lastPanPos = null; wasPinching = false; pinchCenter = null;
    isDown = false; previewPos = null; dragStartPos = null; redraw();
  } else if (e.touches.length === 1) {
    lastPinchDist = null; lastPanPos = null; pinchCenter = null;
    if (wasPinching) { wasPinching = false; isDown = false; previewPos = null; redraw(); }
  }
}, {passive:false});

