function drawBoard(b, alpha) {
  const col = SPAN_COLORS[b.spanMM] || SPAN_COLORS[1829];
  const len   = (b.spanMM  / BASE_MM) * U;
  const thick = Math.max(2, (b.widthMM / BASE_MM) * U);
  const x = b.col * U;
  const y = b.row * U;
  const rad = b.angle * Math.PI / 180;

  ctx.save();
  ctx.globalAlpha = alpha;
  ctx.translate(x, y);
  ctx.rotate(rad);

  // 板の塗り
  ctx.fillStyle = col.fill;
  ctx.fillRect(0, -thick/2, len, thick);

  // 板の枠線
  ctx.strokeStyle = col.line;
  ctx.lineWidth = Math.max(1.5, U*0.06);
  ctx.setLineDash([]);
  ctx.strokeRect(0, -thick/2, len, thick);

  // ラベル（幅表示×スパン）
  const fs = Math.max(7, Math.min(11, thick*0.6));
  if (len > 24 && thick > 8) {
    ctx.fillStyle = col.line;
    ctx.font = fs+'px monospace';
    ctx.textAlign = 'center';
    ctx.fillText((BOARD_WIDTH_LABEL[b.widthMM]||b.widthMM)+'×'+b.spanMM, len/2, fs*0.38);
  }

  ctx.restore();

  // 消去モード時は始点に✕マークを表示（回転なし）
  if (tool === 'erase') {
    const r = Math.max(12, U*0.6);
    ctx.save();
    // 赤い円背景
    ctx.fillStyle = '#e03e3ecc';
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI*2);
    ctx.fill();
    // 白い✕
    ctx.strokeStyle = '#ffffff';
    ctx.lineWidth = Math.max(2, r*0.25);
    ctx.lineCap = 'round';
    const d = r * 0.5;
    ctx.beginPath(); ctx.moveTo(x-d, y-d); ctx.lineTo(x+d, y+d); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+d, y-d); ctx.lineTo(x-d, y+d); ctx.stroke();
    ctx.restore();
  }
}

function drawBoardPreview() {
  if (!previewPos || tool !== 'board') return;
  const dummy = {col: previewPos.col, row: previewPos.row, spanMM: boardSpan, widthMM: boardWidth, angle: boardAngle};
  drawBoard(dummy, 0.4);
