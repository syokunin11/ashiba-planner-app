<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>足場プランナー</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@400;500;700&display=swap');
  :root {
    --bg:#1a1e2a;--surface:#222736;--surface2:#2a3045;
    --accent:#00d4ff;--accent2:#f4a100;
    --sep:#2a3555;--text:#c8d0e0;--text-dim:#5a6480;
    --radius:10px;--danger:#e03e3e;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  body{font-family:'Noto Sans JP',sans-serif;background:var(--bg);color:var(--text);height:100dvh;display:flex;flex-direction:column;overflow:hidden;}

  header{padding:8px 14px 6px;background:var(--surface);border-bottom:1px solid var(--sep);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
  header h1{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;color:var(--accent);line-height:1;}
  header .sub{font-size:9px;color:var(--text-dim);margin-top:1px;}

  .toolbar{display:flex;align-items:center;gap:5px;padding:6px 10px;background:var(--surface);border-bottom:1px solid var(--sep);flex-shrink:0;overflow-x:auto;scrollbar-width:none;}
  .toolbar::-webkit-scrollbar{display:none;}
  .tsep{width:1px;height:18px;background:var(--sep);flex-shrink:0;margin:0 2px;}
  .tlabel{font-size:10px;color:var(--text-dim);flex-shrink:0;white-space:nowrap;}
  .tbtn{flex-shrink:0;padding:5px 11px;border-radius:14px;border:1px solid var(--sep);background:transparent;color:var(--text-dim);font-size:11px;font-family:'Noto Sans JP',sans-serif;font-weight:500;cursor:pointer;transition:all 0.15s;white-space:nowrap;}
  .tbtn.at{background:var(--accent);border-color:var(--accent);color:#000;font-weight:700;}
  .tbtn.et{background:var(--danger);border-color:var(--danger);color:#fff;font-weight:700;}
  .tbtn.mt{background:#22cc88;border-color:#22cc88;color:#000;font-weight:700;}
  .tbtn.bkt{background:#ff8c00;border-color:#ff8c00;color:#000;font-weight:700;}
  .tbtn.ht{background:#00d4ff;border-color:#00d4ff;color:#000;font-weight:700;}
  .tbtn.disabled{opacity:0.3;pointer-events:none;}
  .tbtn.aw{background:#a259ff;border-color:#a259ff;color:#fff;font-weight:700;}
  .tbtn.as{background:var(--accent2);border-color:var(--accent2);color:#000;font-weight:700;}

  .canvas-wrap{flex:1;overflow:auto;background:#0a0c12;padding:6px;}
  canvas{display:block;touch-action:none;cursor:crosshair;}

  .stat-bar{display:flex;gap:10px;padding:5px 12px;background:var(--surface2);border-top:1px solid var(--sep);font-size:11px;color:var(--text-dim);flex-shrink:0;}
  .stat-item span{color:var(--accent);font-weight:700;}

  .controls{background:var(--surface);border-top:1px solid var(--sep);flex-shrink:0;}
  .ctrl-row{display:flex;align-items:center;gap:8px;padding:6px 12px;border-bottom:1px solid var(--sep);}
  .ctrl-lbl{font-size:11px;color:var(--text-dim);white-space:nowrap;min-width:32px;}
  .seg-btn{padding:4px 10px;border-radius:12px;border:1px solid var(--sep);background:transparent;color:var(--text-dim);font-size:11px;font-family:'Noto Sans JP',sans-serif;font-weight:500;cursor:pointer;transition:all 0.15s;}
  .seg-btn.active{border-color:var(--accent2);color:var(--accent2);font-weight:700;background:#f4a10015;}
  .dan-counter{display:flex;align-items:center;gap:6px;}
  .dan-btn{width:26px;height:26px;border-radius:50%;border:none;font-size:16px;font-weight:bold;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .dan-btn.minus{background:var(--surface2);color:var(--text);}
  .dan-btn.plus{background:var(--accent2);color:#000;}
  .dan-val{font-size:18px;font-weight:700;color:var(--accent2);min-width:22px;text-align:center;}
  .btn-row{display:flex;gap:8px;padding:7px 12px;}
  .calc-btn{flex:1;padding:11px;background:var(--accent2);color:#000;border:none;border-radius:var(--radius);font-size:13px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .calc-btn:active{background:#d98e00;}
  .clear-btn{padding:11px 14px;background:transparent;color:var(--danger);border:1px solid var(--danger);border-radius:var(--radius);font-size:12px;font-weight:600;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}

  .toolbar2{border-top:none;}
  .legend-inline{display:flex;gap:8px;align-items:center;flex-shrink:0;}
  .legend-item{display:flex;align-items:center;gap:3px;font-size:10px;color:var(--text-dim);}
  .ldot{width:9px;height:9px;border-radius:2px;border:1.5px solid;flex-shrink:0;}

  /* メニューボタン */
  .menu-btn{background:transparent;border:1px solid var(--sep);color:var(--text);font-size:18px;width:36px;height:36px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .menu-btn:active{background:var(--surface2);}

  /* メニューパネル */
  .menu-overlay{display:none;position:fixed;inset:0;background:#00000077;z-index:300;}
  .menu-overlay.visible{display:block;}
  .menu-panel{position:absolute;top:0;right:0;width:min(320px,90vw);height:100%;background:var(--surface);display:flex;flex-direction:column;box-shadow:-4px 0 20px #0008;}
  .menu-header{display:flex;justify-content:space-between;align-items:center;padding:16px;border-bottom:1px solid var(--sep);flex-shrink:0;}
  .menu-title{font-size:16px;font-weight:700;color:var(--text);}
  .menu-close{background:transparent;border:1px solid var(--sep);color:var(--text);font-size:18px;width:32px;height:32px;border-radius:50%;cursor:pointer;}
  .menu-tabs{display:flex;border-bottom:1px solid var(--sep);flex-shrink:0;overflow-x:auto;scrollbar-width:none;}
  .menu-tabs::-webkit-scrollbar{display:none;}
  .menu-tab{flex-shrink:0;padding:10px 10px;background:transparent;border:none;border-bottom:2px solid transparent;color:var(--text-dim);font-size:12px;font-family:'Noto Sans JP',sans-serif;font-weight:500;cursor:pointer;transition:all 0.15s;white-space:nowrap;}
  .menu-tab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:700;}

  /* バージョン */
  .version-badge{display:inline-block;background:var(--accent);color:#000;font-size:13px;font-weight:700;padding:6px 14px;border-radius:20px;margin-bottom:4px;}
  .update-list{display:flex;flex-direction:column;gap:16px;}
  .update-item{background:var(--surface2);border-radius:10px;padding:14px;}
  .update-ver{font-size:13px;font-weight:700;color:var(--accent);margin-bottom:2px;}
  .update-date{font-size:11px;color:var(--text-dim);margin-bottom:8px;}
  .update-notes{display:flex;flex-direction:column;gap:4px;}
  .update-note{font-size:13px;color:var(--text);}

  /* プライバシー */
  .privacy-text{display:flex;flex-direction:column;gap:16px;}
  .privacy-section{background:var(--surface2);border-radius:10px;padding:14px;}
  .privacy-heading{font-size:13px;font-weight:700;color:var(--accent2);margin-bottom:6px;}
  .privacy-body{font-size:12px;color:var(--text);line-height:1.7;}

  /* お問い合わせ */
  .contact-body{display:flex;flex-direction:column;gap:14px;}
  .contact-desc{font-size:13px;color:var(--text);line-height:1.7;}
  .contact-item{background:var(--surface2);border-radius:10px;padding:14px;}
  .contact-label{font-size:11px;color:var(--text-dim);margin-bottom:4px;}
  .contact-value{font-size:14px;color:var(--accent);font-weight:600;}
  .contact-note{font-size:11px;color:var(--text-dim);}
  .feedback-list{display:flex;flex-direction:column;gap:8px;}
  .feedback-item{background:var(--surface2);border-radius:8px;padding:12px;font-size:13px;color:var(--text);}

  .tbtn.bdt{background:#4488ff;border-color:#4488ff;color:#fff;font-weight:700;}
  .tbtn.bd-active{background:#ff8c00;border-color:#ff8c00;color:#000;font-weight:700;}
  .board-angle-label{font-size:12px;color:var(--accent);min-width:36px;text-align:center;font-weight:700;}
  .board-slider{flex:1;min-width:80px;max-width:160px;accent-color:var(--accent);}
  .memo-panel{display:flex;align-items:center;gap:8px;padding:6px 12px;background:#1a2a1a;border-bottom:2px solid #22cc88;flex-shrink:0;flex-wrap:wrap;}

  /* 建地調整パネル */
  .kenchi-panel{display:flex;align-items:center;gap:8px;padding:6px 12px;background:#1a1a2a;border-bottom:2px solid #a259ff;flex-shrink:0;flex-wrap:wrap;}

  /* 離れパネル */
  .hanare-panel{display:flex;align-items:center;gap:8px;padding:6px 12px;background:#1a2a3a;border-bottom:2px solid #00d4ff;flex-shrink:0;flex-wrap:wrap;}
  .hanare-title{font-size:11px;color:#00d4ff;font-weight:700;white-space:nowrap;}
  .hanare-scope-row{display:flex;gap:4px;}
  .hanare-scope-btn{padding:4px 10px;border-radius:8px;border:1px solid #00d4ff44;background:transparent;color:var(--text-dim);font-size:11px;font-family:'Noto Sans JP',sans-serif;cursor:pointer;white-space:nowrap;}
  .hanare-scope-btn.active{background:#00d4ff;color:#000;font-weight:700;border-color:#00d4ff;}
  .hanare-quick{display:flex;gap:6px;}
  .hanare-q-btn{padding:6px 10px;background:#00d4ff22;color:#00d4ff;border:1px solid #00d4ff;border-radius:8px;font-size:12px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .hanare-input-row{display:flex;gap:6px;align-items:center;}
  .hanare-input{width:80px;background:var(--surface2);border:1px solid var(--sep);border-radius:8px;padding:6px 10px;color:var(--text);font-size:16px;font-family:'Noto Sans JP',sans-serif;outline:none;}
  .hanare-apply-btn{padding:6px 14px;background:#00d4ff;color:#000;border:none;border-radius:8px;font-size:12px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .hanare-cancel-btn{padding:6px 10px;background:transparent;color:var(--danger);border:1px solid var(--danger);border-radius:8px;font-size:12px;cursor:pointer;}
  .keisan-display{font-size:40px;font-weight:300;color:var(--text);text-align:right;padding:8px 4px 0;min-height:56px;word-break:break-all;line-height:1.2;}
  .keisan-sub{font-size:16px;color:var(--text-dim);text-align:right;padding:0 4px 8px;min-height:24px;}
  .keisan-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;}
  .kbtn{padding:0;height:60px;border:none;border-radius:50%;font-size:20px;font-weight:500;cursor:pointer;font-family:'Noto Sans JP',sans-serif;transition:opacity 0.1s;background:#333a4d;color:var(--text);}
  .kbtn:active{opacity:0.7;}
  .kbtn.func{background:#636e7e;color:#fff;}
  .kbtn.op{background:var(--accent2);color:#000;font-weight:700;}
  .kbtn.eq{background:var(--accent2);color:#000;font-weight:700;}
  .kbtn.zero{border-radius:30px;grid-column:span 2;text-align:left;padding-left:22px;}
  .menu-content{flex:1;overflow-y:auto;padding:16px;}
  .menu-sec-title{font-size:11px;color:var(--text-dim);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;}

  /* 色設定 */
  .color-row-wrap{border-bottom:1px solid var(--sep);padding:12px 0;}
  .color-row-wrap:last-child{border-bottom:none;}
  .color-row-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
  .color-row-label{font-size:14px;color:var(--text);font-weight:600;}
  .color-cur-dot{font-size:11px;padding:3px 10px;border-radius:12px;border:2px solid;color:#000;font-weight:700;}
  .cgroups{display:flex;flex-direction:column;gap:6px;}
  .cgroup{display:flex;align-items:center;gap:6px;}
  .cgroup-label{font-size:10px;color:var(--text-dim);min-width:52px;flex-shrink:0;}
  .cgroup-swatches{display:flex;gap:6px;}
  .cswatch{width:30px;height:30px;border-radius:8px;border:2px solid transparent;cursor:pointer;transition:transform 0.1s;flex-shrink:0;}
  .cswatch:active{transform:scale(0.85);}
  .cswatch.sel{border-color:#fff;transform:scale(1.15);}

  /* 人工計算 */
  .calc-group{margin-bottom:14px;}
  .calc-label{font-size:12px;color:var(--text-dim);margin-bottom:6px;font-weight:600;}
  .calc-input{width:100%;background:var(--surface2);border:1px solid var(--sep);border-radius:8px;padding:12px 14px;color:var(--text);font-size:16px;font-family:'Noto Sans JP',sans-serif;outline:none;}
  .calc-input:focus{border-color:var(--accent);}
  .ratio-row{display:flex;align-items:center;gap:12px;background:var(--surface2);border-radius:10px;padding:12px 14px;}
  .ratio-item{display:flex;flex-direction:column;align-items:center;gap:6px;}
  .ratio-label{font-size:12px;font-weight:600;white-space:nowrap;}
  .ratio-counter{display:flex;align-items:center;gap:8px;}
  .ratio-btn{width:32px;height:32px;border-radius:50%;border:none;background:var(--surface);color:var(--text);font-size:18px;font-weight:bold;cursor:pointer;flex-shrink:0;}
  .ratio-val{font-size:24px;font-weight:700;color:var(--text);min-width:24px;text-align:center;}
  .ratio-val-fixed{font-size:24px;font-weight:700;color:#00d4ff;text-align:center;white-space:nowrap;}
  .ratio-sep{font-size:20px;color:var(--text-dim);font-weight:700;white-space:nowrap;}
  .calc-result-box{background:var(--surface2);border-radius:12px;padding:16px;margin:16px 0;border:1px solid var(--sep);}
  .calc-result-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;}
  .calc-result-label{font-size:13px;color:var(--text-dim);}
  .calc-result-value{font-size:18px;font-weight:700;color:var(--accent);}
  .calc-result-divider{height:1px;background:var(--sep);margin:6px 0;}
  .highlight-green .calc-result-label{color:#22cc88;}
  .highlight-green .calc-result-value{color:#22cc88;font-size:22px;}
  .highlight-blue .calc-result-label{color:#00d4ff;}
  .highlight-blue .calc-result-value{color:#00d4ff;font-size:22px;}
  .calc-reset-btn{width:100%;padding:10px;background:transparent;color:var(--danger);border:1px solid var(--danger);border-radius:8px;font-size:13px;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .reflect-btn{width:100%;padding:12px;background:#22cc88;color:#000;border:none;border-radius:8px;font-size:13px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;margin-top:8px;}

  /* 人工管理 */
  .prog-section{margin-bottom:16px;}
  .prog-site-row{display:flex;gap:8px;align-items:center;}
  .prog-select{flex:1;background:var(--surface2);border:1px solid var(--sep);border-radius:8px;padding:10px 12px;color:var(--text);font-size:14px;font-family:'Noto Sans JP',sans-serif;outline:none;}
  .prog-add-btn{padding:10px 14px;background:var(--accent);color:#000;border:none;border-radius:8px;font-size:13px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;white-space:nowrap;}
  .prog-add-form{margin-top:10px;padding:12px;background:var(--surface2);border-radius:10px;}
  .prog-summary{background:var(--surface2);border-radius:12px;padding:14px;margin-bottom:14px;}
  .prog-summary-name{font-size:16px;font-weight:700;color:var(--text);margin-bottom:12px;}
  .prog-summary-row{display:flex;gap:8px;margin-bottom:12px;}
  .prog-summary-item{flex:1;background:var(--surface);border-radius:8px;padding:10px;text-align:center;}
  .prog-summary-label{font-size:10px;color:var(--text-dim);margin-bottom:4px;}
  .prog-summary-val{font-size:18px;font-weight:700;color:var(--accent);}
  .prog-summary-val.used{color:var(--accent2);}
  .prog-summary-val.remain{color:#22cc88;}
  .prog-bar-wrap{height:10px;background:var(--surface);border-radius:5px;overflow:hidden;margin-bottom:4px;}
  .prog-bar{height:100%;background:var(--accent2);border-radius:5px;transition:width 0.3s;}
  .prog-bar-label{font-size:11px;color:var(--text-dim);text-align:right;}
  .prog-date-row{display:flex;gap:6px;align-items:center;}
  .prog-history-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--sep);}
  .prog-history-item:last-child{border-bottom:none;}
  .prog-history-date{font-size:13px;color:var(--text);}
  .prog-history-val{font-size:16px;font-weight:700;color:var(--accent2);}
  .prog-history-del{background:transparent;border:none;color:var(--danger);font-size:16px;cursor:pointer;padding:4px 8px;}
  .info-list{display:flex;flex-direction:column;gap:8px;}
  .info-row{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text);}
  .info-row span{color:var(--accent);font-weight:700;min-width:52px;flex-shrink:0;}

  /* 凡例info */
  .legend-info-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--sep);font-size:13px;color:var(--text);}
  .legend-info-row:last-child{border-bottom:none;}
  .legend-info-dot{width:20px;height:20px;border-radius:4px;border:2px solid;flex-shrink:0;}

  .modal-overlay{display:none;position:fixed;inset:0;background:#00000099;z-index:100;align-items:flex-end;}
  .modal-overlay.visible{display:flex;}
  .modal{width:100%;max-height:80dvh;background:var(--surface);border-radius:16px 16px 0 0;overflow-y:auto;border-top:2px solid var(--accent);}
  .modal-header{position:sticky;top:0;background:var(--surface);padding:12px 16px 8px;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid var(--sep);}
  .modal-title{font-size:13px;color:var(--accent);font-weight:700;letter-spacing:1px;}
  .modal-sub{font-size:11px;color:var(--text-dim);margin-top:2px;}
  .modal-close{width:30px;height:30px;border-radius:50%;border:1px solid var(--sep);background:var(--surface2);color:var(--text);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .result-sec{padding:8px 16px 2px;font-size:10px;color:var(--text-dim);font-weight:700;letter-spacing:1px;text-transform:uppercase;border-top:1px solid var(--sep);}
  .result-row{display:flex;justify-content:space-between;align-items:center;padding:9px 16px;border-bottom:1px solid #ffffff08;}
  .result-row:last-child{border-bottom:none;}
  .rname{font-size:14px;color:var(--text);}
  .rqty{font-size:20px;font-weight:700;color:var(--accent2);}
  .runit{font-size:11px;color:var(--text-dim);margin-left:2px;}
  /* 保存・読み込み */
  .save-input-row{display:flex;gap:8px;margin-bottom:4px;}
  .save-input{flex:1;background:var(--surface2);border:1px solid var(--sep);border-radius:8px;padding:10px 12px;color:var(--text);font-size:14px;font-family:'Noto Sans JP',sans-serif;outline:none;}
  .save-input:focus{border-color:var(--accent);}
  .save-btn{padding:10px 16px;background:var(--accent);color:#000;border:none;border-radius:8px;font-size:13px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;white-space:nowrap;}
  .save-btn:active{background:#00aad4;}
  .saved-item{background:var(--surface2);border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
  .saved-item-info{flex:1;min-width:0;}
  .saved-item-title{font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .saved-item-date{font-size:11px;color:var(--text-dim);margin-top:2px;}
  .saved-item-blocks{font-size:11px;color:var(--accent);margin-top:1px;}
  .saved-item-btns{display:flex;gap:6px;flex-shrink:0;}
  .load-btn{padding:6px 12px;background:var(--accent2);color:#000;border:none;border-radius:6px;font-size:12px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;}
  .del-btn{padding:6px 10px;background:transparent;color:var(--danger);border:1px solid var(--danger);border-radius:6px;font-size:12px;cursor:pointer;}

</style>
</head>
<body>

<header>
  <div>
    <h1>足場プランナー</h1>
    <div class="sub" id="header-sub">幅: 610mm / スパン: 1829mm / 縦置き</div>
  </div>
  <button class="menu-btn" onclick="openMenu()">☰</button>
</header>

<!-- メニューパネル（右からスライド） -->
<div class="menu-overlay" id="menu-overlay" onclick="closeMenuOverlay(event)">
  <div class="menu-panel" onclick="event.stopPropagation()">
    <div class="menu-header">
      <div class="menu-title">メニュー</div>
      <button class="menu-close" onclick="closeMenu()">×</button>
    </div>
    <div class="menu-tabs">
      <button class="menu-tab active" id="tab-info"     onclick="switchTab('info')">📖 使い方</button>
      <button class="menu-tab"        id="tab-keisan"   onclick="switchTab('keisan')">🧮 計算機</button>
      <button class="menu-tab"        id="tab-calc"     onclick="switchTab('calc')">🔢 人工計算</button>
      <button class="menu-tab"        id="tab-progress" onclick="switchTab('progress')">📅 人工管理</button>
      <button class="menu-tab"        id="tab-save"     onclick="switchTab('save')">💾 保存</button>
