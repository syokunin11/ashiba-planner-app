const PROG_KEY = 'ashiba_progress';
let currentSite = null;
let siteRatio = 6; // 現場追加時の比率

function getProgData() {
  try { return JSON.parse(localStorage.getItem(PROG_KEY) || '{}'); }
  catch(e) { return {}; }
}
function saveProgData(data) {
  localStorage.setItem(PROG_KEY, JSON.stringify(data));
}

function buildProgSelect() {
  const data = getProgData();
  const sel = document.getElementById('prog-site-select');
  const cur = sel.value;
  sel.innerHTML = '<option value="">-- 現場を選択 --</option>';
  Object.keys(data).forEach(name => {
    const opt = document.createElement('option');
    opt.value = name; opt.textContent = name;
    if (name === cur) opt.selected = true;
    sel.appendChild(opt);
  });
}

let liveRatio = 6; // サマリー上での比率変更用

function changeSiteRatioNew(d) {
  siteRatio = Math.min(9, Math.max(1, siteRatio + d));
  document.getElementById('site-ratio-kumi').textContent = siteRatio;
  document.getElementById('site-ratio-kai').textContent  = 10 - siteRatio;
}

function changeSiteRatioLive(d) {
  liveRatio = Math.min(9, Math.max(1, liveRatio + d));
  document.getElementById('prog-ratio-kumi').textContent = liveRatio;
  document.getElementById('prog-ratio-kai').textContent  = 10 - liveRatio;
}

function applyRatioLive() {
  if (!currentSite) return;
  const data = getProgData();
  if (!data[currentSite]) return;
  const target = data[currentSite].target;
  data[currentSite].ratio      = liveRatio;
  data[currentSite].kumiTarget = parseFloat((target * liveRatio / 10).toFixed(2));
  data[currentSite].kaiTarget  = parseFloat((target * (10 - liveRatio) / 10).toFixed(2));
  saveProgData(data);
  updateProgView();
}
function showAddSite() {
  document.getElementById('prog-add-form').style.display = 'block';
  siteRatio = 6;
  document.getElementById('site-ratio-kumi').textContent = 6;
  document.getElementById('site-ratio-kai').textContent  = 4;
  document.getElementById('prog-site-calc-result').style.display = 'none';
  document.getElementById('prog-sqm').value   = '';
  document.getElementById('prog-tanka').value = '';
  document.getElementById('prog-joyo').value  = '';
  document.getElementById('prog-site-name').value = '';
}
function hideAddSite() { document.getElementById('prog-add-form').style.display='none'; }

function calcSiteTarget() {
  const sqm   = parseFloat(document.getElementById('prog-sqm').value);
  const tanka = parseFloat(document.getElementById('prog-tanka').value);
  const joyo  = parseFloat(document.getElementById('prog-joyo').value);
  if (!sqm || !tanka || !joyo) {
    document.getElementById('prog-site-calc-result').style.display = 'none';
    return;
  }
  const koji  = sqm * tanka;
  const total = koji / joyo;
  document.getElementById('prog-koji-disp').textContent   = '¥' + Math.round(koji).toLocaleString();
  document.getElementById('prog-target-auto').textContent = total.toFixed(2) + ' 人工';
  document.getElementById('prog-site-calc-result').style.display = 'block';
}

function addSite() {
  const name  = document.getElementById('prog-site-name').value.trim();
  const sqm   = parseFloat(document.getElementById('prog-sqm').value);
  const tanka = parseFloat(document.getElementById('prog-tanka').value);
  const joyo  = parseFloat(document.getElementById('prog-joyo').value);
  if (!name)              { alert('現場名を入力してください'); return; }
  if (!sqm || !tanka || !joyo) { alert('平米数・平米単価・常用金額を入力してください'); return; }

  const target     = parseFloat((sqm * tanka / joyo).toFixed(2));
  const kumiTarget = parseFloat((target * siteRatio / 10).toFixed(2));
  const kaiTarget  = parseFloat((target * (10-siteRatio) / 10).toFixed(2));

  const data = getProgData();
  if (data[name]) { alert('同じ名前の現場がすでにあります'); return; }
  data[name] = { target, kumiTarget, kaiTarget, ratio: siteRatio, sqm, tanka, joyo, records: [] };
  saveProgData(data);

  hideAddSite();
  buildProgSelect();
  document.getElementById('prog-site-select').value = name;
  selectSite();
}

function selectSite() {
  const name = document.getElementById('prog-site-select').value;
  currentSite = name || null;
  const hasSite = !!currentSite;
  document.getElementById('prog-summary').style.display         = hasSite ? 'block' : 'none';
  document.getElementById('prog-input-section').style.display   = hasSite ? 'block' : 'none';
  document.getElementById('prog-history-section').style.display = hasSite ? 'block' : 'none';
  document.getElementById('prog-delete-section').style.display  = hasSite ? 'block' : 'none';
  if (!hasSite) return;

  const today = new Date();
  const yyyy = today.getFullYear();
  const mm = String(today.getMonth()+1).padStart(2,'0');
  const dd = String(today.getDate()).padStart(2,'0');
  document.getElementById('prog-date').value = `${yyyy}-${mm}-${dd}`;

  // 比率表示を初期化
  const sdata = getProgData();
  liveRatio = (sdata[name] && sdata[name].ratio) ? sdata[name].ratio : 6;
  document.getElementById('prog-ratio-kumi').textContent = liveRatio;
  document.getElementById('prog-ratio-kai').textContent  = 10 - liveRatio;

  updateProgView();
}

function updateProgView() {
  if (!currentSite) return;
  const data = getProgData();
  const site = data[currentSite];
  if (!site) return;

  const kumiUsed = site.records.filter(r=>r.type==='kumi').reduce((s,r)=>s+r.val,0);
  const kaiUsed  = site.records.filter(r=>r.type==='kai').reduce((s,r)=>s+r.val,0);
  const totalUsed = kumiUsed + kaiUsed;
  const remain    = site.target - totalUsed;
  const pct       = Math.min(100, Math.round(totalUsed / site.target * 100));

  // 合計
  document.getElementById('prog-summary-name').textContent = currentSite;
  // 現場の基本情報を表示
  const infoEl = document.getElementById('prog-site-info');
  if (infoEl) {
    if (site.sqm && site.tanka && site.joyo) {
      infoEl.textContent = site.sqm + '㎡ ／ 単価 ¥' + site.tanka.toLocaleString() + ' ／ 常用 ¥' + site.joyo.toLocaleString();
      infoEl.style.display = 'block';
    } else {
      infoEl.style.display = 'none';
    }
  }
  document.getElementById('prog-target-disp').textContent  = site.target.toFixed(2);
  document.getElementById('prog-used-disp').textContent    = totalUsed.toFixed(2);
  document.getElementById('prog-remain-disp').textContent  = remain.toFixed(2);
  document.getElementById('prog-remain-disp').style.color  = remain < 0 ? 'var(--danger)' : '#22cc88';
  document.getElementById('prog-bar').style.width          = pct + '%';
  document.getElementById('prog-bar').style.background     = pct >= 100 ? 'var(--danger)' : 'var(--accent2)';
  document.getElementById('prog-bar-label').textContent    = pct + '% 消化';

  // 組立・解体
  const kumiTarget  = site.kumiTarget != null ? site.kumiTarget : parseFloat((site.target * 0.6).toFixed(2));
  const kaiTarget   = site.kaiTarget  != null ? site.kaiTarget  : parseFloat((site.target * 0.4).toFixed(2));
  const kumiRemain  = kumiTarget - kumiUsed;
  const kaiRemain   = kaiTarget  - kaiUsed;

  document.getElementById('prog-kumi-target').textContent = kumiTarget.toFixed(2);
  document.getElementById('prog-kumi-used').textContent   = kumiUsed.toFixed(2);
  document.getElementById('prog-kumi-remain').textContent = kumiRemain.toFixed(2);
  document.getElementById('prog-kumi-remain').style.color = kumiRemain < 0 ? 'var(--danger)' : '#22cc88';
  document.getElementById('prog-kai-target').textContent  = kaiTarget.toFixed(2);
  document.getElementById('prog-kai-used').textContent    = kaiUsed.toFixed(2);
  document.getElementById('prog-kai-remain').textContent  = kaiRemain.toFixed(2);
  document.getElementById('prog-kai-remain').style.color  = kaiRemain < 0 ? 'var(--danger)' : '#22cc88';

  // 履歴
  const sorted = [...site.records].sort((a,b)=>b.date.localeCompare(a.date));
  const el = document.getElementById('prog-history-list');
  if (sorted.length === 0) {
    el.innerHTML = '<div style="color:var(--text-dim);font-size:13px;padding:12px 0;">まだ入力がありません</div>';
  } else {
    el.innerHTML = sorted.map((r,i) => {
      const typeLabel = r.type==='kumi' ? '🔧 組立' : '🔨 解体';
      const typeColor = r.type==='kumi' ? '#22cc88' : '#00d4ff';
      return '<div class="prog-history-item">'+
        '<div>'+
        '<div class="prog-history-date">📅 '+r.date.replace(/-/g,'/')+'</div>'+
        '<div style="font-size:11px;color:'+typeColor+';">'+typeLabel+'</div>'+
        '</div>'+
        '<div style="display:flex;align-items:center;gap:8px;">'+
        '<div class="prog-history-val">'+r.val.toFixed(2)+' 人工</div>'+
        '<button class="prog-history-del" onclick="deleteRecord('+i+')">✕</button>'+
        '</div></div>';
    }).join('');
  }
}

function addNinku() {
  const date = document.getElementById('prog-date').value;
  const val  = parseFloat(document.getElementById('prog-ninku').value);
  const type = document.getElementById('prog-type').value;
  if (!date) { alert('日付を選択してください'); return; }
  if (!val || val <= 0) { alert('人工数を入力してください'); return; }

  const data = getProgData();
  if (!data[currentSite]) return;
  data[currentSite].records.push({ date, val, type });
  saveProgData(data);
  document.getElementById('prog-ninku').value = '';
  updateProgView();
}

function deleteRecord(idx) {
  const data = getProgData();
  if (!data[currentSite]) return;
  const sorted = [...data[currentSite].records].sort((a,b)=>b.date.localeCompare(a.date));
  const target = sorted[idx];
  data[currentSite].records = data[currentSite].records.filter(r =>
    !(r.date===target.date && r.val===target.val && r.type===target.type)
  );
  saveProgData(data);
  updateProgView();
}

function deleteSite() {
  if (!currentSite) return;
  const btn = document.querySelector('.calc-reset-btn[onclick="deleteSite()"]');
  if (!btn) return;

  // 確認UIに差し替え
  const wrap = btn.parentNode;
  btn.style.display = 'none';
  const confirmEl = document.createElement('div');
  confirmEl.id = 'delete-confirm';
  confirmEl.innerHTML =
    '<div style="font-size:13px;color:var(--danger);text-align:center;margin-bottom:8px;">「'+currentSite+'」を削除しますか？</div>'+
    '<div style="display:flex;gap:8px;">'+
