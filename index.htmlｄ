// ===== アンドゥ・リドゥ =====
function saveHistory() {
  undoStack.push(JSON.stringify({blocks, memos, boards}));
  redoStack = [];
  updateUndoButtons();
}

function undo() {
  if (undoStack.length === 0) return;
  redoStack.push(JSON.stringify({blocks, memos, boards}));
  const state = JSON.parse(undoStack.pop());
  blocks = state.blocks; memos = state.memos || []; boards = state.boards || [];
  updateUndoButtons();
  redraw();
}

function redo() {
  if (redoStack.length === 0) return;
  undoStack.push(JSON.stringify({blocks, memos, boards}));
  const state = JSON.parse(redoStack.pop());
  blocks = state.blocks; memos = state.memos || []; boards = state.boards || [];
  updateUndoButtons();
  redraw();
}

function updateUndoButtons() {
  document.getElementById('btn-undo').className = undoStack.length > 0 ? 'tbtn' : 'tbtn disabled';
  document.getElementById('btn-redo').className = redoStack.length > 0 ? 'tbtn' : 'tbtn disabled';
}

